---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext, safeJsonLdSerialize } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { resolvePageMeta } from "../lib/page-meta.js";
import { shouldBlockSearchIndexing } from "../lib/search-indexing.js";
import { SITE_FAVICON_PATH, SITE_LOGO_PATH, SITE_NAME } from "../lib/structured-data.js";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	pageType?: string;
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	breadcrumbs?: Array<{ name: string; url: string }>;
	structuredData?: unknown[];
}

const {
	title,
	description,
	image,
	canonical,
	content,
	pageType = "website",
	publishedTime,
	modifiedTime,
	author,
	breadcrumbs,
	structuredData = [],
} = Astro.props;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "" || Astro.url.pathname.endsWith("/index.html");
const blockSearchIndexing = shouldBlockSearchIndexing(Astro.url.hostname);
const resolvedPageMeta = resolvePageMeta({
	url: Astro.url,
	canonical,
	image,
});

const faviconHref = SITE_FAVICON_PATH;
const logoSrc = SITE_LOGO_PATH;
const displayLogoBase = "/images/logo-red-transparent-cropped";
const displayLogoSizes = "(min-width: 961px) 144px, 120px";
const primaryLinks = [
	{ label: "Categories", url: "/categories" },
	{ label: "Submit", url: "/submit-game" },
	{ label: "Blog", url: "/blog" },
];
const resolvedBreadcrumbs = breadcrumbs ?? (isHome ? [] : undefined);

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType,
	title,
	description,
	canonical: resolvedPageMeta.canonical,
	image: resolvedPageMeta.image,
	content,
	articleMeta:
		pageType === "article"
			? {
					publishedTime,
					modifiedTime,
					author,
				}
			: undefined,
	siteName: pageType === "article" ? SITE_NAME : undefined,
	siteUrl: pageType === "article" ? Astro.url.origin : undefined,
	breadcrumbs: resolvedBreadcrumbs,
});

---

<!doctype html>
<html lang="en">
	<head>
			<meta charset="UTF-8" />
			<meta name="viewport" content="width=device-width, initial-scale=1.0" />
			<meta name="theme-color" content="#b14e2c" />
			<meta name="color-scheme" content="light" />
			<title>{title}</title>
			<link rel="icon" type="image/svg+xml" href={faviconHref} />
			<link rel="apple-touch-icon" href={logoSrc} />
			{blockSearchIndexing && <meta name="robots" content="noindex, nofollow, noarchive" />}
			{
				structuredData.map((item) => (
					<script is:inline type="application/ld+json" set:html={safeJsonLdSerialize(item)} />
				))
			}
			<script
				is:inline
				async
				src="https://cdn.countvisits.com/script.js"
				data-website-id="f0d91ef3-c5e8-4908-b0a5-aadd7ce53edb"
			></script>
			<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header header-transparent">
			<nav class="nav-shell">
				<a href="/" class="brand">
					<picture class="brand-logo-picture">
						<source
							type="image/avif"
							srcset={`${displayLogoBase}-288.avif 288w, ${displayLogoBase}-576.avif 576w`}
							sizes={displayLogoSizes}
						/>
						<source
							type="image/webp"
							srcset={`${displayLogoBase}-288.webp 288w, ${displayLogoBase}-576.webp 576w`}
							sizes={displayLogoSizes}
						/>
						<img
							class="brand-logo"
							src={logoSrc}
							alt="TTRPG Games"
							width="987"
							height="543"
							decoding="async"
							fetchpriority="high"
						/>
					</picture>
					<span class="brand-copy">
						<strong>TTRPG Games Directory</strong>
						<small>Discover your next tabletop roleplay game.</small>
					</span>
				</a>
				<details class="mobile-nav">
					<summary class="mobile-nav-toggle">
						<span>Menu</span>
						<span class="mobile-nav-icon" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
						</span>
					</summary>
					<div class="mobile-nav-panel">
						<div class="mobile-nav-links">
							{primaryLinks.map((item) => (
								<a href={item.url} class="mobile-nav-link">
									{item.label}
								</a>
							))}
						</div>
						<div class="mobile-nav-search">
							<LiveSearch
								class="header-search-component"
								style="display:block;width:100%;max-width:none;inline-size:100%;"
								inputClass="header-search-input"
								resultsClass="header-search-results"
								placeholder="Search directory"
								collections={["games", "category_pages"]}
								searchPage="/search"
								routeMap={{ games: "/item/:path", category_pages: "/category/:path" }}
							/>
						</div>
					</div>
				</details>
				<div class="nav-links">
					{primaryLinks.map((item) => (
						<a href={item.url} class="nav-link">
							{item.label}
						</a>
					))}
				</div>
				<div class="nav-search">
						<LiveSearch
							class="header-search-component"
							style="display:block;width:100%;max-width:none;inline-size:100%;"
							inputClass="header-search-input"
							resultsClass="header-search-results"
							placeholder="Search directory"
							collections={["games", "category_pages"]}
							searchPage="/search"
							routeMap={{ games: "/item/:path", category_pages: "/category/:path" }}
						/>
				</div>
			</nav>
		</header>

		<main class="page-shell">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-main">
				<div class="footer-brand">
					<a href="/" class="brand">
						<picture class="brand-logo-picture">
							<source
								type="image/avif"
								srcset={`${displayLogoBase}-288.avif 288w, ${displayLogoBase}-576.avif 576w`}
								sizes={displayLogoSizes}
							/>
							<source
								type="image/webp"
								srcset={`${displayLogoBase}-288.webp 288w, ${displayLogoBase}-576.webp 576w`}
								sizes={displayLogoSizes}
							/>
							<img
								class="brand-logo"
								src={logoSrc}
								alt="TTRPG Games"
								width="987"
								height="543"
								decoding="async"
								loading="lazy"
							/>
						</picture>
						<span class="brand-copy">
							<strong>TTRPG Games Directory</strong>
						</span>
					</a>
					<p class="footer-description">
						A guide for players to compare systems, discover new genres, 
						and find the game that fits their group’s soul. Curated by the 
						community and editorial team.
					</p>
				</div>
				
				<div class="footer-nav-groups">
					<div class="footer-nav-group">
						<strong>Explore</strong>
						<ul>
							<li><a href="/">Home</a></li>
							<li><a href="/categories">All Categories</a></li>
							<li><a href="/blog">Editorial Blog</a></li>
						</ul>
					</div>
					
					<div class="footer-nav-group">
						<strong>Community</strong>
						<ul>
							<li><a href="/#top-rated-games">Top Rated Games</a></li>
							<li><a href="/#recently-added-games">Recently Added</a></li>
							<li><a href="/submit-game">Submit a Game</a></li>
						</ul>
					</div>
					
					<div class="footer-nav-group">
						<strong>Connect</strong>
						<ul>
							<li><a href="https://x.com/augustinbralley">Follow on X</a></li>
							<li><a href="mailto:augustin.bralley@gmail.com">Email Inquiries</a></li>
						</ul>
					</div>
				</div>
			</div>

			<div class="footer-bottom">
				<div class="footer-bottom-content">
					<div class="footer-copyright">
						<span>© 2026 TTRPG Games Directory. All rights reserved.</span>
					</div>
					<div class="footer-legal">
						<a href="/terms-of-use">Terms of Use</a>
						<span class="dot">·</span>
						<a href="/privacy-policy">Privacy Policy</a>
					</div>
				</div>
			</div>
		</footer>

		<EmDashBodyEnd page={pageCtx} />
		<script
			is:inline
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token":"11b79f02395c4857bf13d47f7dd30178"}'
		></script>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f8f3ed;
		--surface: rgba(255, 255, 255, 0.88);
		--surface-strong: #fffdfc;
		--surface-glass: rgba(255, 255, 255, 0.72);
		--line: rgba(120, 97, 74, 0.12);
		--line-strong: rgba(120, 97, 74, 0.22);
		--text: #1a1614;
		--muted: #6b5f53;
		--accent: #b14e2c;
		--accent-strong: #8a3a1d;
		--accent-soft: rgba(177, 78, 44, 0.12);
		--gold-accent: #c4a052;
		--gold-soft: rgba(196, 160, 82, 0.15);
		--pill: rgba(122, 51, 29, 0.04);
		--success: #2f6f4f;
		--shadow: 0 24px 48px rgba(31, 26, 22, 0.1);
		--shadow-soft: 0 12px 24px rgba(31, 26, 22, 0.06);
		--radius: 20px;
		--font-serif: "Spectral", "Iowan Old Style", "Palatino Linotype", serif;
		font-family: var(--font-serif);
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-up {
		animation: fade-up 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background:
			radial-gradient(circle at top right, rgba(243, 215, 200, 0.18), transparent 24%),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.68), transparent 18%),
			linear-gradient(180deg, #fbf8f4 0%, var(--bg) 100%);
		color: var(--text);
	}

	body {
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.site-header,
	.page-shell,
	.site-footer {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
	}

	.site-header {
		padding: 18px 0 18px;
		position: relative;
		z-index: 100;
	}

	.header-transparent {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		width: 100%;
		max-width: none;
		padding-inline: max(16px, (100vw - 1180px) / 2);
		padding-block: 0 !important;
		z-index: 1000;
	}

	.header-transparent .nav-shell {
		background: transparent !important;
		border-color: transparent !important;
		box-shadow: none !important;
		padding-inline: 0 !important;
		padding-block: 8px !important;
	}

	.header-transparent .nav-shell::before {
		display: none;
	}

	.header-transparent .brand-copy strong {
		font-weight: 800;
	}

	.nav-shell {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 32px;
		padding: 16px 18px;
		border: 1px solid var(--line);
		border-radius: 22px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 252, 247, 0.88));
		box-shadow: 0 10px 26px rgba(31, 26, 22, 0.04);
		overflow: visible;
	}

	.mobile-nav {
		display: none;
	}

	.nav-shell::before {
		content: "";
		position: absolute;
		inset: 0 0 auto;
		height: 3px;
		background: linear-gradient(90deg, rgba(177, 78, 44, 0.75), rgba(177, 78, 44, 0.12));
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
	}

	.brand-logo {
		width: 144px;
		height: auto;
		flex: 0 0 auto;
		filter: drop-shadow(0 4px 10px rgba(31, 26, 22, 0.08));
	}

	.brand-logo-picture {
		display: inline-flex;
		flex: 0 0 auto;
	}

	.brand-copy {
		display: grid;
		gap: 3px;
		min-width: 0;
	}

	.brand-copy strong {
		font-size: 1.18rem;
		letter-spacing: 0.015em;
	}

	.brand-copy small {
		color: var(--muted);
		font-size: 0.92rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

		.nav-links {
			display: inline-flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 18px;
			justify-self: end;
		}

	.nav-link {
		position: relative;
		padding: 8px 2px;
		border-radius: 0;
		font-size: 0.97rem;
		color: var(--muted);
		transition: color 0.18s ease;
	}

	.nav-link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 2px;
		height: 1.5px;
		background: linear-gradient(90deg, var(--accent), transparent);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.18s ease;
	}

	.nav-link:hover {
		color: var(--text);
	}

	.nav-link:hover::after {
		transform: scaleX(1);
	}

	.nav-search {
		position: relative;
		z-index: 20;
			min-width: 0;
			width: 100%;
			display: block;
			justify-self: stretch;
		}

		.nav-search > .header-search-component,
		.nav-search emdash-live-search.header-search-component,
		.nav-search .header-search-component,
		.nav-search .header-search-component form,
		.nav-search .header-search-component .emd-search-form {
			width: 100% !important;
			max-width: none;
			min-width: 0;
			display: block !important;
			inline-size: 100%;
		}

		.nav-search .header-search-input,
		.nav-search .header-search-component input,
		.nav-search .header-search-component input[type="search"] {
			width: 100%;
			border: 1px solid var(--line);
			border-radius: 14px;
			padding: 12px 18px;
			background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(251, 246, 240, 0.92));
			box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
			appearance: none;
			font: inherit;
			font-size: 0.95rem;
			line-height: 1.2;
			color: var(--text);
		}

		.nav-search .header-search-input:focus,
		.nav-search .header-search-component input:focus,
		.nav-search .header-search-component input[type="search"]:focus {
			outline: none;
			border-color: var(--line-strong);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.82),
				0 0 0 4px rgba(177, 78, 44, 0.08);
		}

		.nav-search .header-search-input::placeholder,
		.nav-search .header-search-component input::placeholder,
		.nav-search .header-search-component input[type="search"]::placeholder {
			color: var(--muted);
			opacity: 1;
			font-size: 0.92rem;
		}

	.mobile-nav-search {
		position: relative;
		z-index: 20;
	}

	.mobile-nav-search > .header-search-component,
	.mobile-nav-search emdash-live-search.header-search-component,
	.mobile-nav-search .header-search-component,
	.mobile-nav-search .header-search-component form,
	.mobile-nav-search .header-search-component .emd-search-form {
		width: 100% !important;
		max-width: none;
		min-width: 0;
		display: block !important;
		inline-size: 100%;
	}

	.page-shell {
		padding-bottom: 56px;
	}

	.site-footer {
		margin-top: 120px;
		padding-bottom: 48px;
		color: var(--muted);
	}

	.footer-main {
		display: grid;
		grid-template-columns: 1.2fr 2fr;
		gap: 80px;
		padding: 60px 40px;
		background: var(--surface-glass);
		border: 1px solid var(--line);
		border-radius: 32px;
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: 0 20px 50px rgba(31, 26, 22, 0.04);
	}

	.footer-brand {
		display: grid;
		gap: 24px;
		align-content: start;
	}

	.footer-brand .brand-logo {
		width: 120px;
	}

	.footer-description {
		font-size: 1.05rem;
		line-height: 1.6;
		color: var(--muted);
		max-width: 320px;
		margin: 0;
	}

	.footer-nav-groups {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
	}

	.footer-nav-group {
		display: grid;
		gap: 20px;
		align-content: start;
	}

	.footer-nav-group strong {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--text);
		font-weight: 800;
	}

	.footer-nav-group ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 12px;
	}

	.footer-nav-group a {
		font-size: 1rem;
		color: var(--muted);
		transition: color 0.2s ease;
	}

	.footer-nav-group a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		margin-top: 32px;
		padding: 0 10px;
	}

	.footer-bottom-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 24px;
		border-top: 1px solid var(--line);
		font-size: 0.92rem;
		color: var(--muted);
	}

	.footer-legal {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.footer-legal a:hover {
		color: var(--text);
		text-decoration: underline;
	}

	.footer-legal .dot {
		opacity: 0.3;
	}

	@media (max-width: 960px) {
		.footer-main {
			grid-template-columns: 1fr;
			gap: 48px;
			padding: 40px 24px;
		}
		
		.footer-nav-groups {
			grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
			gap: 32px;
		}

		.footer-bottom-content {
			flex-direction: column;
			gap: 16px;
			text-align: center;
		}
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 0 0 0 12px;
		border-radius: 0;
		background: none;
		border-left: 3px solid rgba(177, 78, 44, 0.75);
		color: var(--accent-strong);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.hero-card,
	.panel,
	.game-card,
	.category-card,
	.meta-card {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--surface);
		box-shadow: var(--shadow-soft);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.hero-card,
	.panel,
	.meta-card {
		padding: 24px;
	}

	.hero-card {
		position: relative;
		padding: 38px 40px;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 244, 0.8)),
			var(--surface);
	}

	.hero-card::before {
		content: "";
		position: absolute;
		inset: 0 0 auto;
		height: 4px;
		background: linear-gradient(90deg, var(--accent), rgba(177, 78, 44, 0.18) 55%, transparent);
	}

	.hero-card::after {
		content: "";
		position: absolute;
		top: -60px;
		right: -40px;
		width: 220px;
		height: 220px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(243, 215, 200, 0.24), transparent 70%);
		pointer-events: none;
	}

	.hero-card > p {
		max-width: 48rem;
		font-size: 1.06rem;
		line-height: 1.7;
	}

	.hero-card h1 {
		font-size: clamp(2.6rem, 4.8vw, 4.5rem);
		line-height: 1.05;
		font-weight: 800;
		letter-spacing: -0.03em;
		text-wrap: pretty;
	}

	.category-hero-card h1 {
		font-size: clamp(2.4rem, 4.2vw, 4.8rem);
		text-wrap: pretty;
	}

	.home-hero-card h1 {
		text-wrap: pretty;
	}

	.item-hero-layout h1 {
		max-width: 14ch;
	}

	.hero-card > :not(img) {
		position: relative;
		z-index: 1;
	}

	.section-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: flex-end;
		gap: 24px;
		margin-bottom: 32px;
	}

	.section-title-group {
		display: grid;
		gap: 8px;
	}

	.section-header h1,
	.section-header h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.section-header p {
		margin: 8px 0 0;
		max-width: 48rem;
		color: var(--muted);
		font-size: 1.15rem;
		line-height: 1.6;
