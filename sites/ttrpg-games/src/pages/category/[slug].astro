---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import { getDb } from "emdash/runtime";
import Base from "../../layouts/Base.astro";
import { buildCategoryPageStructuredData } from "../../lib/structured-data.js";
import type {
	CategoryFaq,
	CategoryGameNote,
	CategoryPageEntry,
	GameEntry,
	RelatedCategoryLink,
} from "../../lib/types";

const ESCAPE_AMPERSAND_PATTERN = /&/g;
const ESCAPE_LT_PATTERN = /</g;
const ESCAPE_GT_PATTERN = />/g;
const ESCAPE_QUOTE_PATTERN = /"/g;
const ESCAPE_APOSTROPHE_PATTERN = /'/g;
const REGEX_ESCAPE_PATTERN = /[.*+?^${}()|[\]\\]/g;

const { slug } = Astro.params;
const { entry: rawCategoryPage } = await getEmDashEntry("category_pages", slug ?? "");
const { entries: rawCategoryPages, cacheHint: categoryPagesCacheHint } =
	await getEmDashCollection("category_pages");
Astro.cache.set(categoryPagesCacheHint);

const categoryPage = rawCategoryPage as unknown as CategoryPageEntry | null;
const allCategoryPages = rawCategoryPages as unknown as CategoryPageEntry[];

if (!slug || !categoryPage) {
	return Astro.redirect("/404");
}

const sourceTaxonomy = categoryPage.data.source_taxonomy ?? null;
const sourceTermSlug = categoryPage.data.source_term_slug ?? null;
const where =
	sourceTaxonomy && sourceTermSlug
		? {
				[sourceTaxonomy]: sourceTermSlug,
			}
		: undefined;
const { entries: rawGames, cacheHint } = await getEmDashCollection("games", where ? { where } : undefined);
Astro.cache.set(cacheHint);
const games = rawGames as unknown as GameEntry[];

const rankedGames = games.toSorted((left, right) => {
	const leftRank = left.data.rank ?? Number.MAX_SAFE_INTEGER;
	const rightRank = right.data.rank ?? Number.MAX_SAFE_INTEGER;
	if (leftRank !== rightRank) return leftRank - rightRank;
	return left.data.title.localeCompare(right.data.title);
});

function asArray<T>(value: unknown): T[] {
	const parsed =
		typeof value === "string"
			? (() => {
					try {
						return JSON.parse(value) as unknown;
					} catch {
						return [];
					}
				})()
			: value;

	return Array.isArray(parsed) ? (parsed as T[]) : [];
}

function normalizeGameNotes(value: unknown): CategoryGameNote[] {
	return asArray<Record<string, unknown>>(value)
		.map((item) => ({
			game_slug: typeof item.game_slug === "string" ? item.game_slug : "",
			fit_blurb: typeof item.fit_blurb === "string" ? item.fit_blurb : "",
			featured: Boolean(item.featured),
			featured_reason: typeof item.featured_reason === "string" ? item.featured_reason : "",
			sort_order:
				typeof item.sort_order === "number"
					? item.sort_order
					: typeof item.sort_order === "string" && item.sort_order.trim()
						? Number(item.sort_order)
						: null,
		}))
		.filter((item) => item.game_slug);
}

function normalizeFaqs(value: unknown): CategoryFaq[] {
	return asArray<Record<string, unknown>>(value)
		.map((item) => ({
			question: typeof item.question === "string" ? item.question : "",
			answer: typeof item.answer === "string" ? item.answer : "",
		}))
		.filter((item) => item.question && item.answer);
}

function normalizeRelatedCategories(value: unknown): RelatedCategoryLink[] {
	return asArray<Record<string, unknown>>(value)
		.map((item) => ({
			slug: typeof item.slug === "string" ? item.slug : "",
			reason: typeof item.reason === "string" ? item.reason : "",
		}))
		.filter((item) => item.slug);
}

const gameNotes = normalizeGameNotes(categoryPage?.data.game_notes);
const gameNotesBySlug = new Map(gameNotes.map((item) => [item.game_slug, item]));
const categoryPagesBySlug = new Map(allCategoryPages.map((item) => [item.id, item]));

function cardCopy(game: GameEntry): string {
	return (
		gameNotesBySlug.get(game.id)?.fit_blurb ||
		game.data.blurb ||
		game.data.review_summary ||
		""
	);
}

const categoryBodyHtml = categoryPage?.data.body_html || null;

const featuredPicks = gameNotes
	.filter((item) => item.featured)
	.map((item) => ({
		note: item,
		game: rankedGames.find((game) => game.id === item.game_slug),
	}))
	.filter((item): item is { note: CategoryGameNote; game: GameEntry } => Boolean(item.game))
	.toSorted((left, right) => {
		const leftOrder = left.note.sort_order ?? Number.MAX_SAFE_INTEGER;
		const rightOrder = right.note.sort_order ?? Number.MAX_SAFE_INTEGER;
		if (leftOrder !== rightOrder) return leftOrder - rightOrder;
		const leftRank = left.game.data.rank ?? Number.MAX_SAFE_INTEGER;
		const rightRank = right.game.data.rank ?? Number.MAX_SAFE_INTEGER;
		if (leftRank !== rightRank) return leftRank - rightRank;
		return left.game.data.title.localeCompare(right.game.data.title);
	});

const faqs = normalizeFaqs(categoryPage?.data.faqs);
const relatedCategories = normalizeRelatedCategories(categoryPage?.data.related_categories)
	.map((item) => ({
		...item,
		page: categoryPagesBySlug.get(item.slug),
	}))
	.filter(
		(item): item is RelatedCategoryLink & { page: CategoryPageEntry } => Boolean(item.page),
	);

const db = await getDb();
const seoRow = categoryPage
	? await db
			.selectFrom("_emdash_seo")
			.select(["seo_title", "seo_description", "seo_image", "seo_canonical"])
			.where("collection", "=", "category_pages")
			.where("content_id", "=", categoryPage.data.id)
			.executeTakeFirst()
	: null;

const pageTitle = seoRow?.seo_title
	? `${seoRow.seo_title} | TTRPG Games Directory`
	: `${categoryPage.data.title} RPGs | TTRPG Games Directory`;
const pageDescription =
	seoRow?.seo_description ||
	categoryPage?.data.description ||
	`Browse tabletop RPGs tagged ${categoryPage.data.title}.`;
const canonical = seoRow?.seo_canonical || Astro.url.href;
const pageImage = seoRow?.seo_image || featuredPicks[0]?.game.data.image_url || null;

const breadcrumbItems = [
	{ name: "Home", url: new URL("/", Astro.url).href },
	{ name: "Categories", url: new URL("/categories", Astro.url).href },
	{ name: categoryPage.data.title, url: Astro.url.href },
];
const structuredData = buildCategoryPageStructuredData({
	origin: Astro.url.origin,
	url: canonical,
	name: categoryPage.data.title,
	description: pageDescription,
	breadcrumbs: breadcrumbItems,
	games: rankedGames,
	faqs,
});

const heroTitle = `Best ${categoryPage.data.title} TTRPGs`;

function escapeHtml(value: string): string {
	return value
		.replace(ESCAPE_AMPERSAND_PATTERN, "&amp;")
		.replace(ESCAPE_LT_PATTERN, "&lt;")
		.replace(ESCAPE_GT_PATTERN, "&gt;")
		.replace(ESCAPE_QUOTE_PATTERN, "&quot;")
		.replace(ESCAPE_APOSTROPHE_PATTERN, "&#39;");
}

function escapeRegExp(value: string): string {
	return value.replace(REGEX_ESCAPE_PATTERN, "\\$&");
}

const faqLinkableGames = rankedGames
	.toSorted((left, right) => right.data.title.length - left.data.title.length)
	.map((game) => ({
		href: `/item/${game.id}`,
		pattern: new RegExp(`\\b${escapeRegExp(game.data.title)}\\b`, "gi"),
	}));

function renderFaqAnswer(answer: string): string {
	let html = "";
	let cursor = 0;

	while (cursor < answer.length) {
		let nextMatch:
			| {
					href: string;
					index: number;
					length: number;
					text: string;
			  }
			| undefined;

		for (const game of faqLinkableGames) {
			game.pattern.lastIndex = 0;
			const segment = answer.slice(cursor);
			const match = game.pattern.exec(segment);
			if (!match || match.index === undefined) continue;

			const candidate = {
				href: game.href,
				index: cursor + match.index,
				length: match[0].length,
				text: match[0],
			};

			if (
				!nextMatch ||
				candidate.index < nextMatch.index ||
				(candidate.index === nextMatch.index && candidate.length > nextMatch.length)
			) {
				nextMatch = candidate;
			}
		}

		if (!nextMatch) {
			html += escapeHtml(answer.slice(cursor));
			break;
		}

		html += escapeHtml(answer.slice(cursor, nextMatch.index));
		html += `<a href="${nextMatch.href}">${escapeHtml(nextMatch.text)}</a>`;
		cursor = nextMatch.index + nextMatch.length;
	}

	return html;
}
---

<Base
	title={pageTitle}
	description={pageDescription}
	canonical={canonical}
	image={pageImage}
	content={categoryPage ? { collection: "category_pages", id: categoryPage.data.id, slug } : undefined}
	breadcrumbs={breadcrumbItems}
	structuredData={structuredData}
>
		<div class="stack animate-up" style="--stack-gap: 60px; gap: var(--stack-gap);">
			<section class="hero-section category-hero">
				<nav class="breadcrumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="breadcrumb-separator">/</span>
					<a href="/categories">Categories</a>
					<span class="breadcrumb-separator">/</span>
					<span aria-current="page" style="color: var(--gold-accent); font-weight: 600;">{categoryPage.data.title}</span>
				</nav>

				<span class="eyebrow">{categoryPage?.data.type || "Category archive"}</span>
				<h1>{heroTitle}</h1>
				{
					categoryBodyHtml && (
						<div class="prose hero-prose" set:html={categoryBodyHtml} />
					)
				}
				{
					!categoryBodyHtml && categoryPage?.data.description && (
						<p class="hero-description">{categoryPage.data.description}</p>
					)
				}
				<div class="hero-actions">
					<span class="stat-badge">{rankedGames.length} games</span>
					<a href="/categories" class="secondary-button">All categories</a>
				</div>
			</section>

			{
				featuredPicks.length > 0 && (
					<section>
						<div class="section-header">
							<div class="section-title-group">
								<div class="kicker" style="color: var(--gold-accent);">Top picks</div>
								<h2>Best games in this category</h2>
								<p>
									Quick starting points if you want the clearest expressions of what
									{` ${categoryPage.data.title} `}
									games do well.
								</p>
							</div>
						</div>
						<div class="grid games">
							{featuredPicks.map(({ game, note }) => (
								<article class="game-card">
									<a href={`/item/${game.id}`}>
										{
											game.data.image_url && (
												<div class="card-image">
													<img src={game.data.image_url} alt={game.data.title} loading="lazy" />
												</div>
											)
										}
										<div class="card-body">
											<div class="kicker" style="color: var(--gold-accent);">Top pick</div>
											<h3>{game.data.title}</h3>
											<p>{note.featured_reason || cardCopy(game)}</p>
										</div>
									</a>
								</article>
							))}
						</div>
					</section>
				)
			}

			{
				faqs.length > 0 && (
					<section class="faq-section">
						<div class="section-header">
							<div class="section-title-group">
								<div class="kicker" style="color: var(--gold-accent);">FAQ</div>
								<h2>Questions players ask</h2>
							</div>
						</div>
						<div class="faq-list">
							{faqs.map((faq) => (
								<details class="faq-item">
									<summary>{faq.question}</summary>
									<div class="faq-answer" set:html={renderFaqAnswer(faq.answer)} />
								</details>
							))}
						</div>
					</section>
				)
			}

			<section>
				<div class="section-header">
					<div class="section-title-group">
						<div class="kicker" style="color: var(--gold-accent);">Full list</div>
						<h2>All games in this category</h2>
					</div>
				</div>
				{
					rankedGames.length === 0 ? (
						<div class="empty-state">No games are currently assigned to this category.</div>
					) : (
						<div class="grid games">
							{rankedGames.map((game) => (
								<article class="game-card">
									<a href={`/item/${game.id}`}>
										{
											game.data.image_url && (
												<div class="card-image">
													<img
														src={game.data.image_url}
														alt={game.data.title}
														loading="lazy"
													/>
												</div>
											)
										}
										<div class="card-body">
											<div class="kicker">
												{game.data.rank
													? `Rank #${game.data.rank}`
													: "Directory entry"}
											</div>
											<h3>{game.data.title}</h3>
											<p>{cardCopy(game)}</p>
										</div>
									</a>
								</article>
							))}
						</div>
					)
				}
			</section>

			{
				relatedCategories.length > 0 && (
					<section>
						<div class="section-header">
							<div class="section-title-group">
								<div class="kicker" style="color: var(--gold-accent);">Keep browsing</div>
								<h2>Related categories</h2>
							</div>
						</div>
						<div class="grid categories">
							{relatedCategories.map((item) => (
								<article class="category-card">
									<a href={`/category/${item.page.id}`}>
										<div class="card-body">
											<div class="kicker" style="color: var(--gold-accent);">{item.page.data.type}</div>
											<h3>{item.page.data.title}</h3>
											<p>{item.reason || item.page.data.description}</p>
										</div>
									</a>
								</article>
							))}
						</div>
					</section>
				)
			}
		</div>
	</Base>

<style>
	.category-hero {
		padding: 150px 0 32px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0;
	}

	.category-hero h1 {
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		line-height: 1.05;
		font-weight: 800;
		letter-spacing: -0.03em;
		margin: 12px 0 0;
	}

	.hero-prose {
		margin-top: 24px;
		max-width: 720px;
		font-size: 1.2rem;
		line-height: 1.6;
		color: var(--muted);
	}

	.hero-description {
		margin-top: 24px;
		font-size: 1.25rem;
		color: var(--muted);
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-top: 32px;
	}

	.stat-badge {
		background: var(--gold-soft);
		color: var(--gold-accent);
		padding: 6px 14px;
		border-radius: 99px;
		font-weight: 700;
		font-size: 0.9rem;
		border: 1px solid var(--gold-accent);
	}

	.secondary-button {
		font-weight: 600;
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.section-header {
		margin-bottom: 40px;
	}

	.section-header h2 {
		font-size: 2.2rem;
		font-weight: 800;
		letter-spacing: -0.01em;
		margin: 8px 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 32px;
	}

	.game-card {
		background: var(--surface-glass);
		border: 1px solid var(--line);
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		backdrop-filter: blur(8px);
	}

	.game-card:hover {
		transform: translateY(-10px) scale(1.02);
		border-color: var(--gold-accent);
		box-shadow: 0 32px 64px rgba(31, 26, 22, 0.15);
	}

	.card-image {
		aspect-ratio: 16/10;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.8s ease;
	}

	.game-card:hover .card-image img {
		transform: scale(1.1);
	}

	.card-body {
		padding: 24px;
	}

	.card-body h3 {
		font-size: 1.5rem;
		font-weight: 800;
		margin: 8px 0;
	}

	.card-body p {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--muted);
	}

	.category-card {
		background: #fff;
		border: 1px solid var(--line);
		border-radius: 24px;
		transition: all 0.4s ease;
	}

	.category-card:hover {
		border-color: var(--accent);
		background: var(--surface-glass);
		transform: translateY(-4px);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 16px;
		max-width: 800px;
	}

	.faq-item {
		background: var(--surface-glass);
		border: 1px solid var(--line);
		border-radius: 16px;
		overflow: hidden;
	}

	.faq-item summary {
		padding: 20px 24px;
		font-weight: 700;
		font-size: 1.1rem;
		cursor: pointer;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.faq-item summary::after {
		content: "+";
		font-size: 1.4rem;
		color: var(--gold-accent);
	}

	.faq-item[open] summary::after {
		content: "−";
	}

	.faq-answer {
		padding: 0 24px 24px;
		line-height: 1.6;
		color: var(--muted);
	}

	.breadcrumbs {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		font-size: 0.9rem;
		margin: 0;
		position: relative;
		z-index: 10;
		color: var(--muted);
	}

	.kicker {
		font-family: var(--font-serif);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.75rem;
		font-weight: 700;
	}

	.eyebrow {
		display: block;
		margin-top: 24px;
		font-family: var(--font-serif);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent);
	}

	@media (max-width: 960px) {
		.category-hero {
			padding: 0 0 32px;
		}
	}
</style>
