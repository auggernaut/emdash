---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import { setAstroCacheHint } from "../lib/astro-cache.js";
import { sortRecentlyAddedGames, topRatedCardLabelFor } from "../lib/home-page-games";
import { isToolPost } from "../lib/post-routes";
import { buildHomePageStructuredData, SITE_NAME } from "../lib/structured-data.js";
import type { Badge, CategoryFaq, CategoryPageEntry, GameEntry, PostEntry } from "../lib/types";

const NON_ALPHANUMERIC_PATTERN = /[^a-z0-9]/g;
const HERO_IMAGE_PLACEHOLDER = "data:image/gif;base64,R0lGODlhAQABAAAAACw=";
const HERO_IMAGE_SIZES = "(min-width: 1200px) 440px, 40vw";
const HERO_IMAGE_BASE = "/home-hero";

const [
	{ entries: rawGames, cacheHint: gamesCacheHint },
	{ entries: rawCategoryPages, cacheHint: categoryPagesCacheHint },
	{ entries: rawPosts, cacheHint: postsCacheHint },
] = await Promise.all([
	getEmDashCollection("games"),
	getEmDashCollection("category_pages"),
	getEmDashCollection("posts"),
]);

setAstroCacheHint(Astro.cache, gamesCacheHint);
setAstroCacheHint(Astro.cache, categoryPagesCacheHint);
setAstroCacheHint(Astro.cache, postsCacheHint);

const games = rawGames as unknown as GameEntry[];
const categoryPages = rawCategoryPages as unknown as CategoryPageEntry[];
const posts = rawPosts as unknown as PostEntry[];
const articles = posts.filter((post) => !isToolPost(post));

const rankedGames = games.toSorted((left, right) => {
	const leftRank = left.data.rank ?? Number.MAX_SAFE_INTEGER;
	const rightRank = right.data.rank ?? Number.MAX_SAFE_INTEGER;
	if (leftRank !== rightRank) return leftRank - rightRank;
	return left.data.title.localeCompare(right.data.title);
});

const topRatedGames = rankedGames.filter((game) => game.data.is_top_rated).slice(0, 8);

const categoryCards = categoryPages.toSorted((left, right) => {
	if (left.data.type !== right.data.type) {
		return left.data.type.localeCompare(right.data.type);
	}
	return left.data.title.localeCompare(right.data.title);
});

const preferredCategoryIds = new Set([
	"fantasy",
	"highfantasy",
	"darkfantasy",
	"sciencefiction",
	"cyberpunk",
	"postapocalyptic",
	"horror",
	"cosmichorror",
]);

function normalizeCategoryId(value: string): string {
	return value.toLowerCase().replace(NON_ALPHANUMERIC_PATTERN, "");
}

const popularCategories = [
	...categoryCards.filter((category) =>
		preferredCategoryIds.has(normalizeCategoryId(category.id))
	),
	...categoryCards.filter(
		(category) => !preferredCategoryIds.has(normalizeCategoryId(category.id))
	),
].slice(0, 9);

const recentlyAddedGames = sortRecentlyAddedGames(games).slice(0, 12);
const pageDescription =
	"Compare TTRPGs, explore category guides, and find the game that best fits your group, campaign style, and taste.";
const faqs: CategoryFaq[] = [
	{
		question: "What does TTRPG mean?",
		answer:
			"TTRPG stands for tabletop roleplaying game. These are games where players create characters, describe what they do, and use rules, prompts, or dice to shape what happens next. Some are tactical and combat-heavy, others are narrative, solo, GM-less, or built for short one-shots.",
	},
	{
		question: "What is TTRPG Games?",
		answer:
			"TTRPG Games is a curated directory and editorial guide for TTRPG discovery. It is designed to help you compare games by genre, mechanics, tone, player count, prep load, and play style so you can quickly figure out which games actually fit your table.",
	},
	{
		question: "How do I use this site to find the right TTRPG?",
		answer:
			"Start with either the Top Rated Games section for strong entry points or the category pages if you already know what you want, like horror, cyberpunk, rules-light, solo-friendly, or beginner-friendly play. Then open individual game pages to compare fit, complexity, prep, session length, and whether a game works best for one-shots, campaigns, or specific player counts.",
	},
	{
		question: "How is this different from a generic best TTRPG list?",
		answer:
			"Instead of pretending there is one universal best game, this site tries to help you find the best fit. It combines category guides with game-level decision data so you can compare whether something is beginner-friendly, solo-friendly, campaign-friendly, rules-light, high-prep, low-prep, or better for a particular mood or table style.",
	},
	{
		question: "Can this site help me find games beyond D&D?",
		answer:
			"Yes. A lot of players come in looking for games like D&D, but lighter, darker, weirder, more narrative, more tactical, or easier to prep. The directory covers fantasy, sci-fi, horror, mystery, post-apocalyptic, and many other genres, along with categories that make it easier to branch out from traditional high-fantasy dungeon crawling.",
	},
	{
		question: "Can I find solo, GM-less, or beginner-friendly TTRPGs here?",
		answer:
			"Yes. The site is not limited to traditional full-group campaigns. It is built to surface niche formats and access points too, including solo-friendly games, one-shot-friendly games, approachable entry points for new players, and categories that narrow by how much structure, prep, or improvisation a game asks from the table.",
	},
	{
		question: "What does Top Rated mean on this site?",
		answer:
			"Top Rated highlights standout directory picks in the current catalog. It is meant as a practical starting shelf, not a claim that one game is objectively best for every group. The better next step is to use those picks as anchors, then compare nearby games by category and fit.",
	},
	{
		question: "Can I submit a game to the directory?",
		answer:
			"Yes. If a game is missing, you can submit it for editorial review through the site’s submission form. That helps the directory keep expanding beyond the usual big names and makes it easier for players to discover interesting indie and overlooked games.",
	},
];
const structuredData = buildHomePageStructuredData({
	origin: Astro.url.origin,
	description: pageDescription,
	faqs,
});

function badgesFor(game: GameEntry):     Badge[] {
	const rawBadges: Array<Badge | null> = [
		game.data.is_top_rated ? { label: "Top rated", tone: "strong" as const } : null,
		game.data.is_free ? { label: "Free", tone: undefined } : null,
		game.data.paid ? { label: "Paid", tone: undefined } : null,
	];
	return rawBadges.filter((badge): badge is Badge => badge !== null);
}

function cardCopy(game: GameEntry): string {
	return game.data.blurb || game.data.review_summary || "";
}
---

<Base
	title={SITE_NAME}
	description={pageDescription}
	structuredData={structuredData}
>
	<div class="stack animate-up" style="--stack-gap: 80px; gap: var(--stack-gap);">
		<section class="hero-section">
			<div class="hero-content">
				<span class="eyebrow" style="color: var(--gold-accent); border-left-color: var(--gold-accent);">
					Find your next adventure
				</span>
				<h1>Find the perfect TTRPG for your group.</h1>
				<p>
					From gritty hex-crawls to epic narrative wonders. Use our curated guides
					to narrow the field and find a system that matches your mechanics, 
					mood, and campaign style.
				</p>
				<div class="hero-stats">
					<div class="stat-pill">
						<strong>{games.length}</strong>
						<span>Games</span>
					</div>
					<div class="stat-pill">
						<strong>{categoryPages.length}</strong>
						<span>Categories</span>
					</div>
					<div class="stat-pill">
						<strong>{articles.length}</strong>
						<span>Articles</span>
					</div>
				</div>
				<div class="hero-actions">
					<a href="/categories" class="button-link primary">Browse all categories</a>
					<a href="/submit-game" class="button-link">Submit a game</a>
				</div>
			</div>
			<div class="hero-visual">
					<div class="hero-image-stack">
						<div class="hero-image-card horror">
							<picture>
								<source
									media="(min-width: 961px)"
									type="image/avif"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_wasteland_hero-512.avif 512w, ${HERO_IMAGE_BASE}/ttrpg_wasteland_hero-960.avif 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/webp"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_wasteland_hero-512.webp 512w, ${HERO_IMAGE_BASE}/ttrpg_wasteland_hero-960.webp 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/png"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_wasteland_hero.png`}
								/>
								<img
									src={HERO_IMAGE_PLACEHOLDER}
									alt="Post-apocalyptic TTRPG players planning a wasteland campaign"
									width="1024"
									height="1024"
									loading="lazy"
									decoding="async"
									fetchpriority="low"
								/>
							</picture>
						</div>
						<div class="hero-image-card superhero">
							<picture>
								<source
									media="(min-width: 961px)"
									type="image/avif"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_superhero_hero-512.avif 512w, ${HERO_IMAGE_BASE}/ttrpg_superhero_hero-960.avif 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/webp"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_superhero_hero-512.webp 512w, ${HERO_IMAGE_BASE}/ttrpg_superhero_hero-960.webp 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/png"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_superhero_hero.png`}
								/>
								<img
									src={HERO_IMAGE_PLACEHOLDER}
									alt="Superhero TTRPG players gathered around a futuristic city map"
									width="1024"
									height="1024"
									loading="lazy"
									decoding="async"
									fetchpriority="low"
								/>
							</picture>
						</div>
						<div class="hero-image-card cyberpunk">
							<picture>
								<source
									media="(min-width: 961px)"
									type="image/avif"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_cyberpunk_hero-512.avif 512w, ${HERO_IMAGE_BASE}/ttrpg_cyberpunk_hero-960.avif 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/webp"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_cyberpunk_hero-512.webp 512w, ${HERO_IMAGE_BASE}/ttrpg_cyberpunk_hero-960.webp 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/png"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_cyberpunk_hero.png`}
								/>
								<img
									src={HERO_IMAGE_PLACEHOLDER}
									alt="Cyberpunk TTRPG"
									width="1024"
									height="1024"
									loading="lazy"
									decoding="async"
									fetchpriority="low"
								/>
							</picture>
						</div>
						<div class="hero-image-card fantasy">
							<picture>
								<source
									media="(min-width: 961px)"
									type="image/avif"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_hero_bg-512.avif 512w, ${HERO_IMAGE_BASE}/ttrpg_hero_bg-960.avif 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/webp"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_hero_bg-512.webp 512w, ${HERO_IMAGE_BASE}/ttrpg_hero_bg-960.webp 960w`}
									sizes={HERO_IMAGE_SIZES}
								/>
								<source
									media="(min-width: 961px)"
									type="image/png"
									srcset={`${HERO_IMAGE_BASE}/ttrpg_hero_bg.png`}
								/>
								<img
									src={HERO_IMAGE_PLACEHOLDER}
									alt="Fantasy TTRPG"
									width="1024"
									height="1024"
									loading="eager"
									decoding="async"
									fetchpriority="high"
								/>
							</picture>
						</div>
					</div>
			</div>
		</section>

		<section id="top-rated-games">
			<div class="section-header">
				<div>
					<div class="kicker">Top picks</div>
					<h2>Top Rated Games</h2>
				</div>
				<p>
					Start with games that consistently stand out for strong player response
					and broad appeal.
				</p>
			</div>
			<div class="grid games">
				{topRatedGames.map((game) => (
					<article class="game-card">
						<a href={`/item/${game.id}`}>
							{
								game.data.image_url && (
									<div class="card-image">
										<img
											src={game.data.image_url}
											alt={game.data.title}
											loading="lazy"
										/>
									</div>
								)
							}
							<div class="card-body">
								<div class="kicker" style={game.data.is_top_rated ? "color: var(--gold-accent); font-weight: 800;" : ""}>
									{game.data.is_top_rated ? "★ " : ""}{topRatedCardLabelFor(game)}
								</div>
								<h3>{game.data.title}</h3>
								<p style="font-size: 0.95rem; line-height: 1.6;">{cardCopy(game)}</p>
								<div class="badges" style="margin-top: 14px;">
									{badgesFor(game).map((badge) => (
										<span class="badge" data-tone={badge.tone}>
											{badge.label}
										</span>
									))}
								</div>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<section>
			<div class="section-header">
				<div>
					<div class="kicker">Explore by category</div>
					<h2>Popular categories</h2>
				</div>
				<p>
					Jump into the genres and play styles players reach for most often when
					they’re narrowing down the field.
				</p>
			</div>
			<div class="grid categories">
				{popularCategories.map((category) => (
					<article class="category-card">
						<a href={`/category/${category.id}`}>
							<div class="card-body">
								<div class="kicker">{category.data.type}</div>
								<h3>{category.data.title}</h3>
								<p>{category.data.description}</p>
							</div>
						</a>
					</article>
				))}
			</div>
			<div class="section-actions">
				<a href="/categories" class="button-link">Browse all categories</a>
			</div>
		</section>

		<section id="recently-added-games">
			<div class="section-header">
				<div>
					<div class="kicker">Fresh discoveries</div>
					<h2>Recently Added Games</h2>
				</div>
				<p>
					Check the newest entries in the current source order and see what’s been
					added to the directory lately.
				</p>
			</div>
			<div class="grid games">
				{recentlyAddedGames.map((game) => (
					<article class="game-card">
						<a href={`/item/${game.id}`}>
							{
								game.data.image_url && (
									<div class="card-image">
										<img
											src={game.data.image_url}
											alt={game.data.title}
											loading="lazy"
										/>
									</div>
								)
							}
							<div class="card-body">
								<div class="kicker">Recently added</div>
								<h3>{game.data.title}</h3>
								<p style="font-size: 0.95rem; line-height: 1.6;">{cardCopy(game)}</p>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="panel animate-up">
			<div class="section-header">
				<div>
					<div class="kicker">Helpful answers</div>
					<h2>FAQs</h2>
				</div>
				<p>
					A quick guide for visitors who are deciding what this site is for, how to
					use it, and which kinds of TTRPGs it can help them find.
				</p>
			</div>
			<div class="faq-grid">
				{faqs.map((faq) => (
					<details class="faq-item">
						<summary>{faq.question}</summary>
						<div class="faq-answer">
							<p>{faq.answer}</p>
						</div>
					</details>
				))}
			</div>
		</section>

		<section class="panel about-site-panel animate-up">
			<div class="section-header about-site-header">
				<div>
					<div class="kicker">Why this exists</div>
					<h2>About This Site</h2>
				</div>
			</div>
			<div class="about-site-body">
				<div class="about-site-content">
					<div class="about-site-copy">
						<p>
							Hey there! I’m on a mission to get more folks hooked on tabletop
							roleplay games. After diving deep into hundreds of TTRPGs to suss out
							what makes each one tick, I’m gathering all the coolest insights in one
							place.
						</p>
						<p>
							I’m also brewing up my own game, so this site doubles as both a
							directory and a running conversation about what makes TTRPGs
							worth loving in the first place.
						</p>
					</div>
					<div class="about-site-footer" style="display: flex; flex-wrap: wrap; align-items: center; gap: 14px; padding-top: 4px;">
						<img
							src="/images/aug-profile-pic.jpg"
							alt="Portrait of Augustin Bralley"
							loading="lazy"
							style="width: 72px; height: 72px; display: block; flex: none; border-radius: 20px; object-fit: cover; object-position: center 18%; box-shadow: 0 10px 24px rgba(31, 26, 22, 0.14); border: 1px solid rgba(255, 255, 255, 0.75);"
						/>
						<div class="about-site-author-meta" style="display: grid; gap: 2px;">
							<div class="about-site-badge" style="color: var(--muted); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;">Curated by</div>
							<div class="about-site-signoff" style="font-weight: 700; letter-spacing: 0.02em; font-size: 1.05rem;">Augustin Bralley</div>
						</div>
						<a href="https://x.com/augustinbralley" class="button-link">
							Follow on X
						</a>
					</div>
				</div>
			</div>
		</section>

		<section id="submit-your-game" class="panel submit-panel animate-up">
			<div class="section-header submit-panel-header">
				<div>
					<div class="kicker">Share a recommendation</div>
					<h2>Submit Your Game</h2>
				</div>
			</div>
			<p class="submit-panel-copy">
				New games are coming out all the time. If there’s a game you’ve played and
				really love that isn’t in the directory yet, send it my way. I’d love to
				review it and add it. If there are any corrections you’d like to make, use
				this form to let me know.
			</p>
			<div class="submit-panel-actions">
				<a href="/submit-game" class="button-link primary">
					Open the submission form
				</a>
			</div>
		</section>
	</div>

	<style>
		.hero-section {
			display: grid;
			grid-template-columns: 1.1fr 0.9fr;
			gap: 60px;
			align-items: center;
			padding: 140px 0 40px;
			min-height: 560px;
		}

		.hero-content h1 {
			font-size: clamp(2.8rem, 5.2vw, 4.8rem);
			line-height: 0.98;
			margin: 24px 0;
			letter-spacing: -0.025em;
			font-weight: 800;
		}

		.hero-content p {
			font-size: 1.25rem;
			color: var(--muted);
			max-width: 560px;
			line-height: 1.6;
		}

		.hero-stats {
			display: flex;
			gap: 32px;
			margin: 36px 0;
		}

		.stat-pill {
			display: flex;
			flex-direction: column;
			gap: 4px;
		}

		.stat-pill strong {
			font-size: 1.6rem;
			color: var(--text);
			font-weight: 800;
		}

		.stat-pill span {
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: var(--muted);
			font-weight: 700;
		}

		.hero-actions {
			display: flex;
			gap: 18px;
			margin-top: 12px;
		}

		.hero-visual {
			perspective: 1200px;
			z-index: 10;
		}
		
		.hero-image-stack {
			position: relative !important;
			height: 480px !important;
			width: 100% !important;
			max-width: 440px !important;
			margin-left: auto;
			display: block !important;
		}

		.hero-image-card {
			position: absolute !important;
			top: 0 !important;
			left: 0 !important;
			width: 100% !important;
			height: 100% !important;
			border-radius: 32px;
			overflow: hidden;
			box-shadow: 0 12px 48px rgba(31, 26, 22, 0.15);
			border: 1px solid rgba(255, 255, 255, 0.1);
			transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
			background: var(--bg);
			display: block !important;
		}

		.hero-image-card img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.hero-image-card picture {
			display: block;
			width: 100%;
			height: 100%;
		}

		/* The Fan */
		.horror { transform: rotate(-10deg) translate(-20px, 10px) !important; z-index: 1 !important; }
		.superhero { transform: rotate(-4deg) translate(-10px, 5px) !important; z-index: 2 !important; }
		.cyberpunk { transform: rotate(4deg) translate(10px, -5px) !important; z-index: 3 !important; }
		.fantasy { transform: rotate(10deg) translate(20px, -10px) !important; z-index: 4 !important; }

		.hero-image-stack:hover .horror { transform: rotate(-18deg) translate(-80px, 40px) scale(1.05) !important; z-index: 10 !important; }
		.hero-image-stack:hover .superhero { transform: rotate(-8deg) translate(-40px, 20px) scale(1.05) !important; z-index: 11 !important; }
		.hero-image-stack:hover .cyberpunk { transform: rotate(8deg) translate(40px, -20px) scale(1.05) !important; z-index: 12 !important; }
		.hero-image-stack:hover .fantasy { transform: rotate(18deg) translate(80px, -40px) scale(1.05) !important; z-index: 13 !important; }

		.hero-image-stack:hover .hero-image-card {
			box-shadow: 0 40px 80px rgba(31, 26, 22, 0.3) !important;
		}

		@media (max-width: 960px) {
			.hero-section {
				grid-template-columns: 1fr;
				text-align: center;
				padding: 0 0 32px;
			}
			.hero-content p {
				margin-inline: auto;
			}
			.hero-stats, .hero-actions {
				justify-content: center;
			}
			.hero-visual {
				display: none;
			}
		}

		/* Match homepage cards to the shared category-card treatment. */
		.game-card {
			background: var(--surface-glass);
			border: 1px solid var(--line);
			border-radius: 24px;
			overflow: hidden;
