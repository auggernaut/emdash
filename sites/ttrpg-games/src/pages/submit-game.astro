---
import Base from "../layouts/Base.astro";

const submitted = Astro.url.searchParams.get("submitted") === "1";
const errorCode = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
	missing_required: "Fill in the required fields before submitting.",
	invalid_website_url: "Enter a valid game website URL starting with http:// or https://.",
	invalid_image_path:
		"Enter a valid image URL or a root-relative path such as /images/cover.png.",
	invalid_email: "Enter a valid email address so the editor can follow up if needed.",
	both_image_inputs: "Choose either an image URL/path or an uploaded image, not both.",
	invalid_image_type: "Upload a JPG, PNG, WEBP, AVIF, or GIF image.",
	image_too_large: "Uploaded images must be 10 MB or smaller.",
	storage_not_configured: "Image uploads are temporarily unavailable. Use an image URL/path instead.",
	forbidden: "This submission was rejected. Reload the page and try again from this site.",
	not_configured: "Submissions are temporarily unavailable.",
	submission_failed: "The submission could not be saved. Try again in a moment.",
};

const errorMessage = errorCode ? errorMessages[errorCode] ?? errorMessages.submission_failed : null;
---

<Base
	title="Submit a Game | TTRPG Games"
	description="Submit a tabletop RPG to the directory for editorial review."
>
	<div class="stack animate-up" style="gap: 56px;">
		<section class="hero-section submit-hero">
			<nav class="breadcrumbs" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="breadcrumb-separator">/</span>
				<span aria-current="page" style="color: var(--gold-accent); font-weight: 600;">Submit a game</span>
			</nav>

			<span class="eyebrow" style="margin-top: 24px; display: block;">Directory Listing</span>
			<h1>Submit a game to the directory.</h1>
			
			<p class="hero-description">
				Send the core details here and the editorial team can review the
				submission and publish it if it belongs in the directory.
			</p>
		</section>

		{
			submitted && (
				<section class="status-banner status-banner-success" id="submission-success">
					<div class="banner-content">
						<strong>Submission received.</strong>
						<p>
							Thanks. The editorial team can now review your submission before it is
							considered for the directory.
						</p>
					</div>
				</section>
			)
		}

		{
			errorMessage && (
				<section class="status-banner status-banner-error" id="submission-error">
					<div class="banner-content">
						<strong>Submission not saved.</strong>
						<p>{errorMessage}</p>
					</div>
				</section>
			)
		}

		<div class="submission-layout">
			<section class="glass-panel submission-card">
				<div class="section-header">
					<div class="section-title-group">
						<div class="kicker-small">Entry Form</div>
						<h2>Game details</h2>
						<p>Required fields are limited to what the editor needs to start a review.</p>
					</div>
				</div>

				<form
					class="submission-form"
					id="game-submission-form"
					action="/api/game-submissions"
					method="post"
					enctype="multipart/form-data"
					data-error-messages={JSON.stringify(errorMessages)}
				>
					<div class="field-grid">
						<label class="field">
							<span>Game title</span>
							<input
								type="text"
								name="title"
								required
								placeholder="For example: Blades in the Dark"
							/>
						</label>

						<label class="field">
							<span>Official website</span>
							<input
								type="url"
								name="websiteUrl"
								required
								placeholder="https://example.com/game"
							/>
						</label>
					</div>

					<label class="field">
						<span>Publisher or creator</span>
						<input
							type="text"
							name="publisherOrCreator"
							placeholder="Designer, studio, or publisher"
						/>
					</label>

					<div class="field-grid">
						<label class="field">
							<span>Your name</span>
							<input
								type="text"
								name="submitterName"
								required
								placeholder="How the editor should refer to you"
							/>
						</label>

						<label class="field">
							<span>Your email</span>
							<input
								type="email"
								name="submitterEmail"
								required
								placeholder="you@example.com"
							/>
						</label>
					</div>

					<label class="field">
						<span>Why it belongs in the directory</span>
						<textarea
							name="description"
							required
							rows="6"
							placeholder="Write a short summary of what the game is, who it suits, and what makes it stand out."
						/>
					</label>

					<div class="field-grid media-grid">
						<label class="field">
							<span>Image URL or site path</span>
							<input
								type="text"
								name="imagePath"
								placeholder="https://example.com/cover.jpg or /images/cover.jpg"
							/>
							<small>Paste an existing hosted image path if you have one.</small>
						</label>

						<label class="field">
							<span>Upload cover image</span>
							<input
								type="file"
								name="imageFile"
								accept="image/jpeg,image/png,image/webp,image/avif,image/gif"
							/>
							<small>Upload instead of pasting a path. Max 10 MB.</small>
						</label>
					</div>

					<label class="field">
						<span>Notes for the editor</span>
						<textarea
							name="submissionNotes"
							rows="4"
							placeholder="Optional: category suggestions, corrections, review links, or anything else that helps with moderation."
						/>
						<small>
							If you’re suggesting a correction, include the item name and the detail
							that needs to be updated so it can be reviewed quickly.
						</small>
					</label>

					<div class="honeypot" aria-hidden="true">
						<label>
							<span>Company</span>
							<input type="text" name="company" tabindex="-1" autocomplete="off" />
						</label>
					</div>

					<div class="form-actions">
						<button type="submit" class="button-link primary">Submit for review</button>
						<p class="muted">
							Submissions are reviewed before anything appears in the directory.
						</p>
					</div>
				</form>
			</section>

			<aside class="stack sidebar-stack" style="gap: 32px;">
				<section class="glass-panel sidebar-panel">
					<div class="kicker-small">Fast track</div>
					<h2>Editorial checklist</h2>
					<ul class="helper-list">
						<li>Use the official game website instead of a storefront mirror when possible.</li>
						<li>Add a clean cover image path or upload so the editor can review presentation quickly.</li>
						<li>Describe tone, player count, complexity, or standout mechanics in plain language.</li>
						<li>Use the notes field for corrections, category suggestions, or useful review links.</li>
					</ul>
				</section>

				<section class="glass-panel sidebar-panel">
					<div class="kicker-small">Review flow</div>
					<h2>What happens next</h2>
					<p>
						Each submission is reviewed by the editorial team, who may revise it,
						follow up for clarification, or add it to the directory if it fits.
					</p>
				</section>
			</aside>
		</div>
	</div>
</Base>

<script is:inline>
	const form = document.querySelector("#game-submission-form");
	if (form instanceof HTMLFormElement) {
		const submitButton = form.querySelector('button[type="submit"]');
		const errorMessages = JSON.parse(form.dataset.errorMessages ?? "{}");

		const renderError = (message) => {
			const initialError = document.querySelector("#submission-error");
			const initialSuccess = document.querySelector("#submission-success");
			if (initialError instanceof HTMLElement) initialError.remove();
			if (initialSuccess instanceof HTMLElement) initialSuccess.remove();
			document.querySelector("#submission-error-runtime")?.remove();

			const banner = document.createElement("section");
			banner.className = "status-banner status-banner-error";
			banner.id = "submission-error-runtime";
			banner.innerHTML = `<div class="banner-content"><strong>Submission not saved.</strong><p>${message}</p></div>`;
			form.closest('.submission-card')?.before(banner);
			banner.scrollIntoView({ behavior: "smooth", block: "nearest" });
		};

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

			try {
				const response = await fetch(form.action, {
					method: form.method,
					body: new FormData(form),
					credentials: "same-origin",
				});

				const finalUrl = new URL(response.url, window.location.href);
				if (finalUrl.searchParams.get("submitted") === "1") {
					window.location.assign(finalUrl.toString());
					return;
				}

				const errorCode = finalUrl.searchParams.get("error") ?? "submission_failed";
				renderError(errorMessages[errorCode] ?? errorMessages.submission_failed);
			} catch {
				renderError(errorMessages.submission_failed);
			} finally {
				if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
			}
		});
	}
</script>

<style>
	.submit-hero {
		padding: 150px 0 32px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0;
	}

	.submit-hero h1 {
		margin: 12px 0 0;
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		line-height: 1.05;
		font-weight: 800;
		letter-spacing: -0.03em;
		text-wrap: pretty;
	}

	.breadcrumbs {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.breadcrumb-separator {
		opacity: 0.5;
	}

	.hero-description {
		margin-top: 24px;
		max-width: 720px;
		font-size: 1.25rem;
		line-height: 1.6;
		color: var(--muted);
	}

	.glass-panel {
		background: var(--surface-glass);
		border: 1px solid var(--line);
		border-radius: 24px;
		padding: 32px;
		backdrop-filter: blur(12px);
		box-shadow: 0 8px 32px rgba(31, 26, 22, 0.05);
	}

	.status-banner {
		padding: 24px;
		border-radius: 20px;
		border: 1px solid;
		margin-bottom: 8px;
	}

	.banner-content {
		display: grid;
		gap: 4px;
	}

	.status-banner p,
	.status-banner strong {
		margin: 0;
	}

	.status-banner-success {
		border-color: rgba(47, 111, 79, 0.2);
		background: rgba(47, 111, 79, 0.05);
		color: #2f6f4f;
	}

	.status-banner-error {
		border-color: rgba(177, 78, 44, 0.2);
		background: rgba(177, 78, 44, 0.05);
		color: #b14e2c;
	}

	.submission-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 380px;
		gap: 48px;
		align-items: start;
	}

	.submission-form {
		display: grid;
		gap: 24px;
		margin-top: 32px;
	}

	.field-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 20px;
	}

	.field {
		display: grid;
		gap: 8px;
	}

	.field span {
		font-weight: 600;
		font-size: 0.88rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
	}

	.field input,
	.field textarea {
		width: 100%;
		padding: 14px 18px;
		border: 1px solid var(--line-strong);
		border-radius: 12px;
		background: white;
		color: var(--text);
		transition: all 0.2s ease;
		font-size: 1rem;
		font-family: inherit;
	}

	.field input::placeholder,
	.field textarea::placeholder {
		color: var(--muted);
		opacity: 0.6;
		font-family: inherit;
	}

	.field input:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--gold-accent);
		box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
	}

	.field input[type="file"] {
		padding: 10px 14px;
		cursor: pointer;
	}

	.field input[type="file"]::file-selector-button {
		background: var(--bg);
		border: 1px solid var(--line-strong);
		padding: 6px 12px;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text);
		margin-right: 12px;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.field input[type="file"]::file-selector-button:hover {
		background: white;
		border-color: var(--gold-accent);
	}

	.field small {
		font-size: 0.85rem;
		color: var(--muted);
		margin-top: 4px;
	}

	.honeypot {
		display: none;
	}

	.form-actions {
		padding-top: 24px;
		border-top: 1px solid var(--line);
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.button-link.primary {
		padding: 16px 32px;
		font-weight: 700;
		border-radius: 12px;
	}

	.section-title-group h2 {
		font-size: 2rem;
		font-weight: 800;
		margin: 8px 0;
	}

	.kicker-small {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--gold-accent);
	}

	.helper-list {
		margin-top: 16px;
		padding-left: 20px;
		display: grid;
		gap: 12px;
		color: var(--muted);
		line-height: 1.5;
	}

	.sidebar-panel h2 {
		font-size: 1.4rem;
		font-weight: 800;
		margin-top: 4px;
	}

	@media (max-width: 960px) {
		.submission-layout {
			grid-template-columns: 1fr;
		}
		.sidebar-stack {
			order: -1;
		}
	}
</style>
