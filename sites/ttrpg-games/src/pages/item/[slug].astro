---
import { getEmDashCollection, getEmDashEntry, getEntryTerms, getSeoMeta } from "emdash";
import Base from "../../layouts/Base.astro";
import { buildGameAgentProfile, buildGameStructuredData } from "../../lib/game-profile";
import type { Badge, GameEntry, RelatedGame } from "../../lib/types";

const DIACRITIC_PATTERN = /[\u0300-\u036f]/g;
const NON_ALPHANUMERIC_PATTERN = /[^a-z0-9]/g;
const HTML_TAG_PATTERN = /<[^>]+>/g;
const AT_A_GLANCE_PARAGRAPH_PATTERN =
	/^<p>\s*(?:<strong>)?\s*At-a-glance:\s*(?:<\/strong>)?\s*([\s\S]*?)<\/p>/i;
const AT_A_GLANCE_PLAIN_PATTERN = /^At-a-glance:\s*([\s\S]*?)(?:\n\s*\n|<h2\b|$)/i;
const LEADING_AT_A_GLANCE_HTML_PATTERN =
	/^<p>\s*(?:<strong>)?\s*At-a-glance:\s*(?:<\/strong>)?\s*[\s\S]*?<\/p>\s*/i;
const LEADING_AT_A_GLANCE_TEXT_PATTERN =
	/^At-a-glance:\s*[\s\S]*?(?:\n\s*\n(?=<)|\n\s*\n|(?=<h2\b)|$)\s*/i;
const HTML_LIKE_PATTERN = /<[a-z][\s\S]*>/i;
const NEWLINE_PATTERN = /\n/g;
const NBSP_ENTITY_PATTERN = /&nbsp;/gi;
const AMP_ENTITY_PATTERN = /&amp;/gi;
const QUOTE_ENTITY_PATTERN = /&quot;/gi;
const APOSTROPHE_ENTITY_PATTERN = /&#39;/gi;
const LT_ENTITY_PATTERN = /&lt;/gi;
const GT_ENTITY_PATTERN = /&gt;/gi;
const ESCAPE_AMPERSAND_PATTERN = /&/g;
const ESCAPE_LT_PATTERN = /</g;
const ESCAPE_GT_PATTERN = />/g;
const ESCAPE_QUOTE_PATTERN = /"/g;
const ESCAPE_APOSTROPHE_PATTERN = /'/g;
const LEGACY_ITEM_SLUG_REDIRECTS = new Map([["agêratos", "ageratos"]]);

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const redirectedSlug = LEGACY_ITEM_SLUG_REDIRECTS.get(slug);
if (redirectedSlug) {
	return Astro.redirect(`/item/${encodeURIComponent(redirectedSlug)}`, 308);
}

const { entry: rawGame, cacheHint } = await getEmDashEntry("games", slug);

if (!rawGame) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const game = rawGame as unknown as GameEntry;
const [genres, systems, mechanics, themes, decisionTags] = await Promise.all([
	getEntryTerms("games", game.data.id, "genre"),
	getEntryTerms("games", game.data.id, "system"),
	getEntryTerms("games", game.data.id, "mechanic"),
	getEntryTerms("games", game.data.id, "theme"),
	getEntryTerms("games", game.data.id, "decision_tag"),
]);

const { entries: rawGames } = await getEmDashCollection("games");
const games = rawGames as unknown as GameEntry[];

const relatedGames: RelatedGame[] = Array.isArray(game.data.related)
	? game.data.related
	: [];

const normalizeLookupValue = (value: string | undefined | null) =>
	(value ?? "")
		.toLowerCase()
		.normalize("NFKD")
		.replace(DIACRITIC_PATTERN, "")
		.replace(NON_ALPHANUMERIC_PATTERN, "");

const canonicalSlugByLookup = new Map<string, string>();

for (const entry of games) {
	canonicalSlugByLookup.set(entry.id, entry.id);
	canonicalSlugByLookup.set(normalizeLookupValue(entry.id), entry.id);
	canonicalSlugByLookup.set(normalizeLookupValue(entry.data.title), entry.id);
}

const resolvedRelatedGames = relatedGames.map((related) => {
	const canonicalSlug =
		canonicalSlugByLookup.get(related.slug) ??
		canonicalSlugByLookup.get(normalizeLookupValue(related.slug)) ??
		canonicalSlugByLookup.get(normalizeLookupValue(related.title)) ??
		related.slug;

	return {
		...related,
		href: `/item/${canonicalSlug}`,
	};
});

const seo = getSeoMeta(game, {
	siteTitle: "TTRPG Games Directory",
	siteUrl: Astro.url.origin,
	path: `/item/${slug}`,
});

const badges: Badge[] = ([
	game.data.rank ? { label: `Rank #${game.data.rank}`, tone: "strong" } : null,
	game.data.is_top_rated ? { label: "Top rated", tone: "strong" } : null,
	game.data.is_free ? { label: "Free" } : null,
	game.data.paid ? { label: "Paid" } : null,
] as (Badge | null)[]).filter((badge): badge is Badge => badge !== null);

const stripTags = (value: string) => value.replace(HTML_TAG_PATTERN, "").trim();

const decodeHtmlEntities = (value: string) =>
	value
		.replace(NBSP_ENTITY_PATTERN, " ")
		.replace(AMP_ENTITY_PATTERN, "&")
		.replace(QUOTE_ENTITY_PATTERN, '"')
		.replace(APOSTROPHE_ENTITY_PATTERN, "'")
		.replace(LT_ENTITY_PATTERN, "<")
		.replace(GT_ENTITY_PATTERN, ">");

const extractAtAGlance = (html?: string | null) => {
	if (!html) return null;

	const trimmed = html.trim();
	const paragraphMatch = trimmed.match(AT_A_GLANCE_PARAGRAPH_PATTERN);

	if (paragraphMatch?.[1]) {
		return decodeHtmlEntities(stripTags(paragraphMatch[1]));
	}

	const plainMatch = trimmed.match(AT_A_GLANCE_PLAIN_PATTERN);

	if (plainMatch?.[1]) {
		return decodeHtmlEntities(stripTags(plainMatch[1]));
	}

	return null;
};

const stripLeadingAtAGlance = (html?: string | null) => {
	if (!html) return html;

	const stripped = html
		.trim()
		.replace(LEADING_AT_A_GLANCE_HTML_PATTERN, "")
		.replace(LEADING_AT_A_GLANCE_TEXT_PATTERN, "");

	return stripped || null;
};

const escapeHtml = (value: string) =>
	value
		.replace(ESCAPE_AMPERSAND_PATTERN, "&amp;")
		.replace(ESCAPE_LT_PATTERN, "&lt;")
		.replace(ESCAPE_GT_PATTERN, "&gt;")
		.replace(ESCAPE_QUOTE_PATTERN, "&quot;")
		.replace(ESCAPE_APOSTROPHE_PATTERN, "&#39;");

const humanizeToken = (value?: string | null) =>
	value
		? value
				.split("-")
				.filter(Boolean)
				.map((part) => part.charAt(0).toUpperCase() + part.slice(1))
				.join(" ")
		: null;

const formatMinutes = (value?: number | null) => (typeof value === "number" ? `${value} min` : null);

const atAGlance = (game.data.at_a_glance?.trim() || extractAtAGlance(game.data.body_html)) ?? null;
const atAGlanceMarkup = atAGlance
	? HTML_LIKE_PATTERN.test(atAGlance)
		? atAGlance
		: `<p>${escapeHtml(atAGlance).replace(NEWLINE_PATTERN, "<br />")}</p>`
	: null;
const bodyHtml = atAGlance ? stripLeadingAtAGlance(game.data.body_html) : game.data.body_html;
const facetGroups = [
	{ label: "Genres", terms: genres, linkToCategory: true },
	{ label: "Systems", terms: systems, linkToCategory: true },
	{ label: "Mechanics", terms: mechanics, linkToCategory: true },
	{ label: "Themes", terms: themes, linkToCategory: true },
	{ label: "Decision Tags", terms: decisionTags, linkToCategory: false },
].filter((group) => group.terms.length > 0);
const agentProfile = buildGameAgentProfile({
	slug,
	game,
		facets: {
			genres,
			systems,
			mechanics,
			themes,
			decisionTags,
		},
	origin: Astro.url.origin,
});
const structuredData = [buildGameStructuredData({ game, agentProfile })];
const profileFacts = [
	{ label: "Players", value: agentProfile.constraints.playerRange },
	{ label: "Session", value: agentProfile.constraints.sessionRange },
	{ label: "Setup", value: formatMinutes(game.data.setup_minutes) },
	{ label: "Character Build", value: formatMinutes(game.data.character_creation_minutes) },
	{ label: "Prep", value: humanizeToken(game.data.prep_level) },
	{ label: "Price", value: humanizeToken(game.data.price_model) },
].filter((item) => item.value);
const playProfile = [
	{ label: "Improv Burden", value: humanizeToken(game.data.improv_burden) },
	{ label: "Structure", value: humanizeToken(game.data.structure_level) },
	{ label: "Content Intensity", value: humanizeToken(game.data.content_intensity) },
].filter((item) => item.value);
const availability = [
	{ label: "Quickstart", value: game.data.quickstart_available === true ? "Available" : null },
	{ label: "PDF", value: game.data.pdf_available === true ? "Available" : null },
	{ label: "Print", value: game.data.physical_book_available === true ? "Available" : null },
	{ label: "VTT", value: game.data.vtt_ready === true ? "Ready" : null },
].filter((item) => item.value);
const fitFlags = [
	{
		label: "Beginner-Friendly",
		value: game.data.beginner_friendly === true ? "Yes" : game.data.beginner_friendly === false ? "No" : null,
	},
	{
		label: "Campaign-Friendly",
		value: game.data.campaign_friendly === true ? "Yes" : game.data.campaign_friendly === false ? "No" : null,
	},
	{
		label: "One-Shot-Friendly",
		value: game.data.one_shot_friendly === true ? "Yes" : game.data.one_shot_friendly === false ? "No" : null,
	},
	{
		label: "Solo-Friendly",
		value: game.data.solo_friendly === true ? "Yes" : game.data.solo_friendly === false ? "No" : null,
	},
].filter((item) => item.value);
const hasDecisionGuideContent =
	profileFacts.length > 0 ||
	agentProfile.scores.length > 0 ||
	playProfile.length > 0 ||
	agentProfile.recommendations.bestFor.length > 0 ||
	agentProfile.recommendations.avoidIf.length > 0 ||
	Boolean(game.data.why_it_fits) ||
	Boolean(agentProfile.agentUrl);
---

<Base
	title={seo.title}
	description={seo.description || game.data.blurb || game.data.review_summary}
	canonical={seo.canonical}
	image={game.data.image_url || seo.ogImage}
	structuredData={structuredData}
	content={{ collection: "games", id: game.data.id, slug }}
>
	<script is:inline type="application/json" id="game-agent-profile" set:html={JSON.stringify(agentProfile)} />
		<div class="stack animate-up" style="gap: 36px;">
			<section class="hero-section detail-hero">
				<nav class="breadcrumbs" aria-label="Breadcrumb" style="margin-bottom: 32px;">
					<a href="/">Home</a>
					<span class="breadcrumb-separator">/</span>
					<a href="/categories">Games</a>
					<span class="breadcrumb-separator">/</span>
					<span aria-current="page" style="color: var(--gold-accent); font-weight: 600;">{game.data.title}</span>
				</nav>

				<div class="detail-layout item-hero-layout">
					<div class="stack" style="gap: 24px;">
						<div class="section-title-group">
							<h1 style="margin: 0;">{game.data.title}</h1>
							<p class="hero-blurb" style="margin-top: 12px; font-size: 1.25rem; color: var(--muted); line-height: 1.6;">
								{game.data.blurb || game.data.review_summary}
							</p>
						</div>

						{
							atAGlanceMarkup && (
								<section class="glass-panel at-a-glance-panel">
									<div class="kicker" style="color: var(--gold-accent);">At-a-glance</div>
									<div class="at-a-glance-copy" style="margin-top: 12px;" set:html={atAGlanceMarkup} />
								</section>
							)
						}

						<div class="meta-row stack" style="gap: 16px;">
							<div class="badges">
								{badges.map((badge) => (
									<span class="badge" data-tone={badge.tone}>
										{badge.label}
									</span>
								))}
							</div>
							{
								facetGroups.length > 0 && (
									<div class="facet-stream" aria-label="Game facets">
										{facetGroups.map((group) => (
											<div class="facet-stream-group">
												<span class="facet-stream-label">{group.label}:</span>
												<div class="term-list">
													{group.terms.map((term) =>
														group.linkToCategory ? (
															<a class="term-pill" href={`/category/${term.slug}`}>
																{term.label}
															</a>
														) : (
															<span class="term-pill">{term.label}</span>
														)
													)}
												</div>
											</div>
										))}
									</div>
								)
							}
						</div>

						<div class="hero-actions" style="display: flex; gap: 12px; margin-top: 8px;">
							{
								game.data.website_url && (
									<a class="button-link primary" href={game.data.website_url}>
										Visit game site
									</a>
								)
							}
							{
								game.data.reviews_url && (
									<a class="button-link" href={game.data.reviews_url}>
										View reviews or buy
									</a>
								)
							}
						</div>
					</div>
				<div class="game-hero">
					{
						game.data.image_url ? (
							<img src={game.data.image_url} alt={game.data.title} />
						) : (
							<div class="meta-card">
								<h2>No artwork imported</h2>
								<p>This entry did not include an image URL in the source tab.</p>
							</div>
						)
					}
				</div>
			</div>
		</section>

		<div class="detail-layout">
			<section class="stack" style="gap: 24px;">
				<section class="panel prose">
					{
						bodyHtml ? (
							<div set:html={bodyHtml} />
						) : (
							<p>{game.data.review_summary || game.data.blurb}</p>
						)
					}
				</section>

				{
					hasDecisionGuideContent && (
						<section class="glass-panel">
							<div class="kicker" style="color: var(--gold-accent);">Decision guide</div>
							<h2>What this game is about</h2>
							<div class="stack" style="gap: 22px; margin-top: 18px;">
								{
									profileFacts.length > 0 && (
										<div class="stack" style="gap: 12px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Key facts</div>
											<div class="fact-grid">
												{profileFacts.map((fact) => (
													<div class="fact-card">
														<div class="fact-label">{fact.label}</div>
														<div class="fact-value">{fact.value}</div>
													</div>
												))}
											</div>
										</div>
									)
								}
								{
									agentProfile.scores.length > 0 && (
										<div class="stack" style="gap: 12px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Play profile</div>
											<div class="score-grid">
												{agentProfile.scores.map((score) => (
													<div class="score-card">
														<div class="score-label">{score.label}</div>
														<div class="score-bar"><span style={`width: ${(score.value / 5) * 100}%`}></span></div>
														<div class="score-value">{score.value}/5</div>
													</div>
												))}
											</div>
										</div>
									)
								}
								{
									playProfile.length > 0 && (
										<div class="stack" style="gap: 10px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Play style</div>
											<div class="term-list">
												{playProfile.map((item) => (
													<span class="term-pill">
														<strong>{item.label}:</strong>&nbsp;{item.value}
													</span>
												))}
											</div>
										</div>
									)
								}
								{
									(agentProfile.recommendations.bestFor.length > 0 ||
										agentProfile.recommendations.avoidIf.length > 0 ||
										game.data.why_it_fits) && (
										<div class="stack" style="gap: 18px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Who it suits</div>
											{
												agentProfile.recommendations.bestFor.length > 0 && (
													<div class="stack" style="gap: 10px;">
														<div class="meta-note" style="margin: 0;">Best for</div>
														<div class="term-list">
															{agentProfile.recommendations.bestFor.map((item) => (
																<span class="term-pill">{item}</span>
															))}
														</div>
													</div>
												)
											}
											{
												agentProfile.recommendations.avoidIf.length > 0 && (
													<div class="stack" style="gap: 10px;">
														<div class="meta-note" style="margin: 0;">Avoid if</div>
														<div class="term-list">
															{agentProfile.recommendations.avoidIf.map((item) => (
																<span class="term-pill term-pill-warning">{item}</span>
															))}
														</div>
													</div>
												)
											}
											{
												game.data.why_it_fits && (
													<p class="panel-copy" style="margin: 0;">{game.data.why_it_fits}</p>
												)
											}
										</div>
									)
								}
								<div class="stack" style="gap: 8px;">
									<div class="meta-note" style="margin: 0; font-weight: 700;">Agent data</div>
									<p class="panel-copy" style="margin: 0;">
										Structured data and an explicit decision profile JSON document are available for
										remote agents.
									</p>
									<p class="meta-note">
										<a href={agentProfile.agentUrl}>Open agent JSON</a>
									</p>
								</div>
							</div>
						</section>
					)
				}
			</section>

			<aside class="stack detail-sidebar" style="gap: 20px;">
				<section class="glass-panel">
					<div class="kicker" style="color: var(--gold-accent);">Review synthesis</div>
					<h2>What players think</h2>
					<div class="panel-content">
						<p class="panel-copy">{game.data.review_summary || "No review synthesis imported."}</p>
						{
							game.data.reviews_url && (
								<p class="meta-note">
									Generated from published player reviews.{" "}
									<a href={game.data.reviews_url}>Read source reviews</a>
								</p>
							)
						}
					</div>
				</section>

				{
					(availability.length > 0 || fitFlags.length > 0) && (
						<section class="glass-panel">
							<div class="kicker" style="color: var(--gold-accent);">Quick fit</div>
							<h2>Operational facts</h2>
							<div class="stack" style="gap: 14px; margin-top: 18px;">
								{
									fitFlags.length > 0 && (
										<div class="stack" style="gap: 8px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Fit flags</div>
											<div class="term-list">
												{fitFlags.map((item) => (
													<span class="term-pill">
														<strong>{item.label}:</strong>&nbsp;{item.value}
													</span>
												))}
											</div>
										</div>
									)
								}
								{
									availability.length > 0 && (
										<div class="stack" style="gap: 8px;">
											<div class="meta-note" style="margin: 0; font-weight: 700;">Availability</div>
											<div class="term-list">
												{availability.map((item) => (
													<span class="term-pill">
														<strong>{item.label}:</strong>&nbsp;{item.value}
													</span>
												))}
											</div>
										</div>
									)
								}
							</div>
						</section>
					)
				}
				{
					resolvedRelatedGames.length > 0 && (
						<section class="glass-panel">
							<div class="kicker" style="color: var(--gold-accent);">Related items</div>
							<h2>More to explore</h2>
							<div class="panel-content">
								<div class="stack" style="gap: 16px;">
									{resolvedRelatedGames.map((related) => (
										<a class="related-item-card" href={related.href}>
											{related.image_url && (
												<img src={related.image_url} alt={related.title} />
											)}
											<div class="related-item-copy">
												<strong>{related.title}</strong>
												{related.description && (
													<div
														class="muted related-description"
														style="margin-top: 8px;"
														set:html={related.description}
													/>
												)}
											</div>
										</a>
									))}
								</div>
							</div>
						</section>
					)
				}
			</aside>
		</div>
	</div>
</Base>

<style>
	.detail-hero {
		padding: 130px 0 24px;
		min-height: auto;
	}

	.item-hero-layout {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 80px;
		align-items: center;
	}

	.item-hero-layout h1 {
		font-size: clamp(2.4rem, 4.2vw, 3.8rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
		font-weight: 800;
	}

	.game-hero img {
		width: 100%;
		max-width: 520px;
		border-radius: 40px;
		box-shadow: 0 32px 64px rgba(31, 26, 22, 0.2);
		transform: rotate(2deg);
		transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.game-hero:hover img {
		transform: rotate(0deg) scale(1.04);
		box-shadow: 0 40px 80px rgba(31, 26, 22, 0.25);
	}

	.glass-panel {
		background: var(--surface-glass);
		border: 1px solid var(--line);
		border-radius: 24px;
		padding: 28px;
		backdrop-filter: blur(12px);
		box-shadow: 0 8px 32px rgba(31, 26, 22, 0.05);
	}

	.glass-panel h2 {
		margin: 8px 0 0;
		font-size: 1.5rem;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.01em;
	}

	.panel-content {
		margin-top: 16px;
	}

	.fact-grid,
	.score-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}

	.fact-card,
	.score-card {
		background: rgba(255, 255, 255, 0.64);
		border: 1px solid var(--line);
		border-radius: 18px;
		padding: 16px;
	}

	.fact-label,
	.score-label {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.fact-value {
		margin-top: 8px;
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1.3;
	}

	.score-bar {
		margin-top: 10px;
		height: 10px;
		border-radius: 999px;
		background: rgba(26, 22, 20, 0.08);
		overflow: hidden;
	}

	.score-bar span {
		display: block;
		height: 100%;
		border-radius: 999px;
		background: linear-gradient(90deg, var(--gold-accent), var(--accent));
	}

	.score-value {
