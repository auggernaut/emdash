---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";

import Base from "../layouts/Base.astro";
import { setAstroCacheHint } from "../lib/astro-cache.js";
import { getPostPath, isToolPost } from "../lib/post-routes";
import type { PostEntry } from "../lib/types";

export const prerender = false;

const PAGE_SIZE = 24;
const ALL_POSTS_LIMIT = 500;

const { entries: rawPosts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: ALL_POSTS_LIMIT,
});

setAstroCacheHint(Astro.cache, cacheHint);

const allPosts = (rawPosts as unknown as PostEntry[]).filter((post) => isToolPost(post));
const posts = allPosts.slice(0, PAGE_SIZE);

function formatDate(date: Date | null | undefined): string | null {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base
	title="Tools | TTRPG Games"
	description="Interactive RPG quizzes, planners, and explainers from TTRPG Games."
>
	<div class="stack blog-shell animate-up">
		<section class="hero-card blog-hero">
			<span class="eyebrow">Tools</span>
			<h1>Tools</h1>
			<p>
				Interactive quizzes, planners, and explainers for choosing systems, shaping sessions,
				and narrowing down what your table wants to play.
			</p>
			<div class="badges" style="margin-top: 18px;">
				<span class="badge">Quizzes</span>
				<span class="badge">Planners</span>
				<span class="badge">Explainers</span>
			</div>
		</section>

		{
			posts.length === 0 ? (
				<section class="panel prose">
					<p>No tool posts are available yet.</p>
				</section>
			) : (
				<section>
					<div class="section-header">
						<div>
							<div class="kicker">What's New?</div>
							<h2>Latest tools</h2>
						</div>
					</div>

					<div class="grid blog-grid" id="tools-grid">
						{posts.map((post) => (
							<article class="blog-card">
								<a href={getPostPath(post.id)} class="blog-card-link">
									{
										post.data.featured_image && (
											<div class="blog-card-image">
												<Image image={post.data.featured_image} />
											</div>
										)
									}
									<div class="card-body">
										<div class="blog-card-meta">
											{formatDate(post.data.publishedAt) && (
												<span class="muted">{formatDate(post.data.publishedAt)}</span>
											)}
										</div>
										<h3>{post.data.title}</h3>
										{post.data.excerpt && <p>{post.data.excerpt}</p>}
									</div>
								</a>
							</article>
						))}
					</div>
				</section>
			)
		}
	</div>
</Base>

<style>
	.blog-shell {
		padding-top: 132px;
	}

	.blog-hero p {
		max-width: 58ch;
	}

	:global(#tools-grid) {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	:global(.blog-card) {
		background: rgba(255, 248, 241, 0.94);
		border: 1px solid var(--line);
		border-radius: 22px;
		overflow: hidden;
		box-shadow: var(--shadow-soft);
		transition: transform 0.18s ease, box-shadow 0.18s ease;
	}

	:global(.blog-card:hover) {
		transform: translateY(-2px);
		box-shadow: 0 26px 58px rgba(39, 24, 13, 0.14);
	}

	:global(.blog-card-link) {
		display: grid;
		color: inherit;
		text-decoration: none;
		height: 100%;
	}

	:global(.blog-card-image img) {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	:global(.blog-card h3) {
		margin: 10px 0 0;
		font-size: clamp(1.1rem, 0.95rem + 0.55vw, 1.45rem);
		line-height: 1.2;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	:global(.blog-card p) {
		margin: 12px 0 0;
		color: var(--muted);
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	:global(.blog-card-meta) {
		display: flex;
		gap: 10px;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}

	:global(#tools-grid .card-body) {
		padding: 18px;
	}

	@media (max-width: 1100px) {
		:global(#tools-grid) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		:global(#tools-grid) {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 900px) {
		.blog-shell {
			padding-top: 0;
		}
	}
</style>
