---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import { Image, PortableText } from "emdash/ui";

import Base from "../../layouts/Base.astro";
import { setAstroCacheHint } from "../../lib/astro-cache.js";
import { getPostPath, isToolPost } from "../../lib/post-routes";
import { buildArticlePageStructuredData } from "../../lib/structured-data.js";
import type { PostEntry } from "../../lib/types";

export const prerender = false;

const LEADING_H1_PATTERN = /^\s*<h1\b[^>]*>[\s\S]*?<\/h1>\s*/i;
const ALL_POSTS_LIMIT = 500;
const RELATED_TOOLS_LIMIT = 3;

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect("/404");
}

const { entry: rawPost, cacheHint } = await getEmDashEntry("posts", slug);
if (!rawPost) {
	return Astro.redirect("/404");
}

setAstroCacheHint(Astro.cache, cacheHint);

const post = rawPost as unknown as PostEntry;
if (!isToolPost(post)) {
	return Astro.redirect(`/blog/${encodeURIComponent(post.id)}`, 308);
}

const { entries: rawToolPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: ALL_POSTS_LIMIT,
});
const toolPosts = (rawToolPosts as unknown as PostEntry[]).filter((entry) => isToolPost(entry));
const currentToolIndex = toolPosts.findIndex((entry) => entry.id === post.id);
const recentPosts =
	currentToolIndex === -1
		? toolPosts.filter((entry) => entry.id !== post.id).slice(0, RELATED_TOOLS_LIMIT)
		: getAdjacentToolPosts(toolPosts, currentToolIndex, RELATED_TOOLS_LIMIT);

function getAdjacentToolPosts(posts: PostEntry[], index: number, limit: number): PostEntry[] {
	const related: PostEntry[] = [];
	let left = index - 1;
	let right = index + 1;

	if (left >= 0) {
		related.push(posts[left]);
		left -= 1;
	}

	if (right < posts.length && related.length < limit) {
		related.push(posts[right]);
		right += 1;
	}

	while (related.length < limit && (left >= 0 || right < posts.length)) {
		if (left >= 0) {
			related.push(posts[left]);
			left -= 1;
		}
		if (right < posts.length && related.length < limit) {
			related.push(posts[right]);
			right += 1;
		}
	}

	return related;
}

function formatDate(date: Date | null | undefined): string | null {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}

function getImageUrl(image: unknown): string | null {
	if (!image || typeof image !== "object") return null;
	const media = image as {
		src?: string;
		id?: string;
		meta?: { storageKey?: string };
	};
	if (media.src) return media.src;
	if (media.meta?.storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${media.meta.storageKey}`;
	}
	if (media.id) {
		return `${Astro.url.origin}/_emdash/api/media/file/${media.id}`;
	}
	return null;
}

const publishedDate = formatDate(post.data.publishedAt);
const updatedDate = formatDate(post.data.updatedAt);
const publishedTime = post.data.publishedAt?.toISOString() ?? null;
const modifiedTime = post.data.updatedAt?.toISOString() ?? null;
const image = getImageUrl(post.data.featured_image);
const bodyHtml = post.data.body_html?.replace(LEADING_H1_PATTERN, "").trim() || null;
const breadcrumbs = [
	{ name: "Home", url: new URL("/", Astro.url).href },
	{ name: "Tools", url: new URL("/tools", Astro.url).href },
	{ name: post.data.title, url: Astro.url.href },
];
const structuredData = buildArticlePageStructuredData({ breadcrumbs });
---

<Base
	title={`${post.data.title} | TTRPG Games`}
	description={post.data.excerpt || null}
	image={image}
	canonical={Astro.url.href}
	pageType="article"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	author="TTRPG Games"
	breadcrumbs={breadcrumbs}
	structuredData={structuredData}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<div class="stack blog-page animate-up">
		<nav class="breadcrumbs">
			<a href="/">Home</a>
			<span class="breadcrumb-separator">/</span>
			<a href="/tools">Tools</a>
			<span class="breadcrumb-separator">/</span>
			<span>{post.data.title}</span>
		</nav>

		<section class="hero-card article-hero">
			<div class="article-hero-copy">
				<div class="badges" style="margin-bottom: 18px;">
					{publishedDate && <span class="badge">{publishedDate}</span>}
					{updatedDate && updatedDate !== publishedDate && (
						<span class="badge">Updated {updatedDate}</span>
					)}
				</div>
				<h1>{post.data.title}</h1>
				{post.data.excerpt && <p>{post.data.excerpt}</p>}
			</div>
			{
				post.data.featured_image && (
					<div class="article-hero-image">
						<Image image={post.data.featured_image} />
					</div>
				)
			}
		</section>

		<section class="panel prose blog-article-body">
			{bodyHtml ? <div set:html={bodyHtml} /> : <PortableText value={post.data.content ?? []} />}
		</section>

		{
			recentPosts.length > 0 && (
				<section class="panel">
					<div class="section-title-group">
						<div class="kicker">Continue reading</div>
						<h2>More tools</h2>
					</div>
					<div class="grid blog-grid related-tools-grid">
						{recentPosts.map((related) => (
							<article class="blog-card">
								<a href={getPostPath(related.id)} class="blog-card-link">
									{
										related.data.featured_image && (
											<div class="blog-card-image">
												<Image image={related.data.featured_image} />
											</div>
										)
									}
									<div class="card-body">
										<div class="blog-card-meta">
											{formatDate(related.data.publishedAt) && (
												<span class="muted">{formatDate(related.data.publishedAt)}</span>
											)}
										</div>
										<h3>{related.data.title}</h3>
										{related.data.excerpt && <p>{related.data.excerpt}</p>}
									</div>
								</a>
							</article>
						))}
					</div>
				</section>
			)
		}

		<div class="article-actions">
			<a href="/tools" class="button-link">Back to tools</a>
			<a href="/categories" class="button-link primary">Browse categories</a>
		</div>
	</div>
</Base>

<style>
	.blog-page {
		padding-top: 132px;
	}

	.article-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 28px;
		align-items: start;
	}

	.article-hero-copy h1 {
		max-width: 12ch;
	}

	.article-hero-image :global(img) {
		width: 100%;
		border-radius: 18px;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		background: linear-gradient(145deg, #e5d7bf, #f7efe3);
	}

	.blog-article-body {
		padding: 30px 32px;
	}

	.blog-article-body :global(h2),
	.blog-article-body :global(h3) {
		text-wrap: pretty;
	}

	.blog-article-body :global(a) {
		color: var(--accent-strong);
		text-decoration: underline;
		text-underline-offset: 0.16em;
	}

	.blog-article-body :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 18px;
	}

	.blog-article-body :global(iframe) {
		width: 100%;
		max-width: 100%;
		aspect-ratio: 16 / 9;
		height: auto;
		border: 0;
		border-radius: 18px;
		background: #111;
	}

	.blog-article-body :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.96rem;
	}

	.blog-article-body :global(th),
	.blog-article-body :global(td) {
		padding: 0.8rem 0.9rem;
		border: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
	}

	.blog-article-body :global(th) {
		background: rgba(255, 248, 241, 0.9);
		font-weight: 700;
	}

	.blog-article-body :global(blockquote) {
		margin: 1.4rem 0;
		padding: 1rem 1.2rem;
		border-left: 3px solid var(--accent);
		background: rgba(255, 248, 241, 0.9);
		color: var(--muted);
	}

	.blog-article-body :global(.sb-banner) {
		display: none !important;
	}

	.related-tools-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 18px;
	}

	.related-tools-grid .blog-card {
		background: rgba(255, 248, 241, 0.94);
		border: 1px solid rgba(111, 78, 55, 0.18);
		border-radius: 22px;
		overflow: hidden;
		box-shadow: var(--shadow-soft);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}

	.related-tools-grid .blog-card:hover {
		transform: translateY(-2px);
		border-color: var(--line-strong);
		box-shadow: 0 26px 58px rgba(39, 24, 13, 0.14);
	}

	.related-tools-grid .blog-card-link {
		display: grid;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.related-tools-grid .blog-card-image :global(img) {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}

	.related-tools-grid .card-body {
		padding: 18px;
	}

	.related-tools-grid .blog-card h3 {
		margin: 10px 0 0;
		font-size: clamp(1.1rem, 0.95rem + 0.55vw, 1.45rem);
		line-height: 1.2;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.related-tools-grid .blog-card p {
		margin: 12px 0 0;
		color: var(--muted);
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.related-tools-grid .blog-card-meta {
		display: flex;
		gap: 10px;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}

	@media (max-width: 860px) {
		.blog-page {
			padding-top: 0;
		}

		.article-hero {
			grid-template-columns: 1fr;
		}

		.article-hero-copy h1 {
			max-width: none;
		}

		.related-tools-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
