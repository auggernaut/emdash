---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found">
	<section class="hero-card">
		<span class="eyebrow">404</span>
		<h1>That page is not in the directory.</h1>
		<p>
			The route could not be resolved in this EmDash site. Return to the main
			directory or browse the imported category pages.
		</p>
		<div class="badges" style="margin-top: 18px;">
			<a href="/" class="button-link primary">Return home</a>
			<a href="/categories" class="button-link">Browse categories</a>
		</div>
	</section>
</Base>
