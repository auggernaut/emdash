---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import type { CategoryPageEntry } from "../../lib/types";

const { entries: rawCategoryPages, cacheHint } =
	await getEmDashCollection("category_pages");
Astro.cache.set(cacheHint);

const categoryPages = rawCategoryPages as unknown as CategoryPageEntry[];

const sortedCategories = [...categoryPages].sort((left, right) => {
	if (left.data.type !== right.data.type) {
		return left.data.type.localeCompare(right.data.type);
	}
	return left.data.title.localeCompare(right.data.title);
});
---

<Base
	title="Browse TTRPG Categories"
	description="Browse tabletop RPG categories by genre, mechanics, and tone to find games that match your group."
>
	<div class="stack">
		<section class="hero-card">
			<span class="eyebrow">Browse by category</span>
			<h1>Find tabletop RPGs by genre, mechanics, and tone.</h1>
			<p>
				Start with the kind of play you want. Browse categories for fantasy,
				horror, cyberpunk, solo play, rules-lite systems, and more, then compare
				games that share those strengths.
			</p>
			<div class="badges" style="margin-top: 18px;">
				<span class="badge">{sortedCategories.length} category guides</span>
			</div>
		</section>

		<section>
			<div class="grid categories">
				{sortedCategories.map((category) => (
					<article class="category-card">
						<a href={`/category/${category.id}`}>
							<div class="card-body">
								<div class="kicker">{category.data.type}</div>
								<h2>{category.data.title}</h2>
								<p>{category.data.description}</p>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>
	</div>
</Base>
