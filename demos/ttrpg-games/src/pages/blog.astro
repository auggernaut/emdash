---
import Base from "../layouts/Base.astro";
---

<Base
	title="Blog | TTRPG Games"
	description="Editorial notes, recommendations, and updates from TTRPG Games."
>
	<div class="stack">
		<section class="hero-card">
			<span class="eyebrow">Editorial</span>
			<h1>Blog</h1>
			<p>
				Longer-form recommendations, category roundups, and editorial updates will
				live here.
			</p>
			<div class="badges" style="margin-top: 18px;">
				<span class="badge">Editorial picks</span>
				<span class="badge">Roundups and updates</span>
			</div>
		</section>

		<section class="panel prose">
			<p>
				The blog section is being prepared. For now, browse the directory through
				the category guides and game pages, or submit a game recommendation for
				editorial review.
			</p>
			<p>
				<a href="/categories" class="button-link primary">Browse categories</a>
			</p>
		</section>
	</div>
</Base>
