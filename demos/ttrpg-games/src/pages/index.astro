---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import type { Badge, CategoryPageEntry, GameEntry } from "../lib/types";

const NON_ALPHANUMERIC_PATTERN = /[^a-z0-9]/g;

const { entries: rawGames, cacheHint } = await getEmDashCollection("games");
const { entries: rawCategoryPages } = await getEmDashCollection("category_pages");
Astro.cache.set(cacheHint);

const games = rawGames as unknown as GameEntry[];
const categoryPages = rawCategoryPages as unknown as CategoryPageEntry[];

const rankedGames = games.toSorted((left, right) => {
	const leftRank = left.data.rank ?? Number.MAX_SAFE_INTEGER;
	const rightRank = right.data.rank ?? Number.MAX_SAFE_INTEGER;
	if (leftRank !== rightRank) return leftRank - rightRank;
	return left.data.title.localeCompare(right.data.title);
});

const topRatedGames = rankedGames.filter((game) => game.data.is_top_rated).slice(0, 8);

const categoryCards = categoryPages.toSorted((left, right) => {
	if (left.data.type !== right.data.type) {
		return left.data.type.localeCompare(right.data.type);
	}
	return left.data.title.localeCompare(right.data.title);
});

const preferredCategoryIds = new Set([
	"fantasy",
	"highfantasy",
	"darkfantasy",
	"sciencefiction",
	"cyberpunk",
	"postapocalyptic",
	"horror",
	"cosmichorror",
]);

function normalizeCategoryId(value: string): string {
	return value.toLowerCase().replace(NON_ALPHANUMERIC_PATTERN, "");
}

const popularCategories = [
	...categoryCards.filter((category) =>
		preferredCategoryIds.has(normalizeCategoryId(category.id))
	),
	...categoryCards.filter(
		(category) => !preferredCategoryIds.has(normalizeCategoryId(category.id))
	),
].slice(0, 9);

const recentlyAddedGames = games.toReversed().slice(0, 12);

const faqs = [
	{
		question: "What are tabletop RPGs?",
		answer:
			"Tabletop RPGs are games where players take on characters in a fictional world and make choices together through conversation, rules, and dice. Some lean tactical, others narrative, but all revolve around collaborative play.",
	},
	{
		question: "How do I choose the right TTRPG for my group?",
		answer:
			"Start with the tone and play style you want. If your group likes story-first play, look for narrative-focused games. If they prefer crunchy combat or character builds, browse categories centered on tactics, skills, or progression.",
	},
	{
		question: "Are these games only fantasy?",
		answer:
			"No. The directory covers fantasy, sci-fi, horror, mystery, post-apocalyptic settings, and more, along with categories for mechanics and campaign style.",
	},
	{
		question: "Where should I begin if I’m new to TTRPGs?",
		answer:
			"Use the top-rated games section for strong starting points, then browse categories to narrow by genre, complexity, or mood. Each game page gives you a quick overview and links to learn more.",
	},
];

function badgesFor(game: GameEntry):     Badge[] {
	const rawBadges: Array<Badge | null> = [
		game.data.is_top_rated ? { label: "Top rated", tone: "strong" as const } : null,
		game.data.is_free ? { label: "Free", tone: undefined } : null,
		game.data.paid ? { label: "Paid", tone: undefined } : null,
	];
	return rawBadges.filter((badge): badge is Badge => badge !== null);
}

function cardCopy(game: GameEntry): string {
	return game.data.blurb || game.data.review_summary || "";
}
---

<Base
	title="TTRPG Games Directory"
	description="Compare tabletop RPGs, explore category guides, and find the game that best fits your group, campaign style, and taste."
>
	<div class="stack animate-up" style="gap: 80px;">
		<section class="hero-section" style="padding: 140px 0 40px;">
			<div class="hero-content">
				<span class="eyebrow" style="color: var(--gold-accent); border-left-color: var(--gold-accent);">
					Find your next adventure
				</span>
				<h1>Discover the tabletop RPG that fits your group’s soul.</h1>
				<p>
					From gritty hex-crawls to epic narrative wonders. Use our curated guides
					to narrow the field and find a system that matches your mechanics, 
					mood, and campaign style.
				</p>
				<div class="hero-stats">
					<div class="stat-pill">
						<strong>{games.length}</strong>
						<span>Systems</span>
					</div>
					<div class="stat-pill">
						<strong>{categoryPages.length}</strong>
						<span>Guides</span>
					</div>
					<div class="stat-pill">
						<span class="gold-star">★</span>
						<span>Top Rated</span>
					</div>
				</div>
				<div class="hero-actions">
					<a href="/categories" class="button-link primary">Browse all categories</a>
					<a href="/submit-game" class="button-link">Submit a game</a>
				</div>
			</div>
			<div class="hero-visual">
				<div class="hero-image-stack">
					<div class="hero-image-card horror">
						<img src="/_emdash/api/media/file/ttrpg_horror_hero.png" alt="Horror TTRPG" />
					</div>
					<div class="hero-image-card space">
						<img src="/_emdash/api/media/file/ttrpg_space_hero.png" alt="Space TTRPG" />
					</div>
					<div class="hero-image-card cyberpunk">
						<img src="/_emdash/api/media/file/ttrpg_cyberpunk_hero.png" alt="Cyberpunk TTRPG" />
					</div>
					<div class="hero-image-card fantasy">
						<img src="/_emdash/api/media/file/ttrpg_hero_bg.png" alt="Fantasy TTRPG" />
					</div>
				</div>
			</div>
		</section>

		<section id="top-rated-games">
			<div class="section-header">
				<div>
					<div class="kicker">Top picks</div>
					<h2>Top Rated Games</h2>
				</div>
				<p>
					Start with games that consistently stand out for strong player response
					and broad appeal.
				</p>
			</div>
			<div class="grid games">
				{topRatedGames.map((game) => (
					<article class="game-card">
						<a href={`/item/${game.id}`}>
							{
								game.data.image_url && (
									<img
										src={game.data.image_url}
										alt={game.data.title}
										loading="lazy"
									/>
								)
							}
							<div class="card-body">
								<div class="kicker" style={game.data.is_top_rated ? "color: var(--gold-accent); font-weight: 800;" : ""}>
									{game.data.is_top_rated ? "★ " : ""}{game.data.rank ? `Rank #${game.data.rank}` : "Directory pick"}
								</div>
								<h3>{game.data.title}</h3>
								<p style="font-size: 0.95rem; line-height: 1.6;">{cardCopy(game)}</p>
								<div class="badges" style="margin-top: 14px;">
									{badgesFor(game).map((badge) => (
										<span class="badge" data-tone={badge.tone}>
											{badge.label}
										</span>
									))}
								</div>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<section>
			<div class="section-header">
				<div>
					<div class="kicker">Explore by category</div>
					<h2>Popular categories</h2>
				</div>
				<p>
					Jump into the genres and play styles players reach for most often when
					they’re narrowing down the field.
				</p>
			</div>
			<div class="grid categories">
				{popularCategories.map((category) => (
					<article class="category-card">
						<a href={`/category/${category.id}`}>
							<div class="card-body">
								<div class="kicker">{category.data.type}</div>
								<h3>{category.data.title}</h3>
								<p>{category.data.description}</p>
							</div>
						</a>
					</article>
				))}
			</div>
			<div class="section-actions">
				<a href="/categories" class="button-link">Browse all categories</a>
			</div>
		</section>

		<section id="recently-added-games">
			<div class="section-header">
				<div>
					<div class="kicker">Fresh discoveries</div>
					<h2>Recently Added Games</h2>
				</div>
				<p>
					Check the newest entries in the current source order and see what’s been
					added to the directory lately.
				</p>
			</div>
			<div class="grid games">
				{recentlyAddedGames.map((game) => (
					<article class="game-card">
						<a href={`/item/${game.id}`}>
							{
								game.data.image_url && (
									<img
										src={game.data.image_url}
										alt={game.data.title}
										loading="lazy"
									/>
								)
							}
							<div class="card-body">
								<div class="kicker">Recently added</div>
								<h3>{game.data.title}</h3>
								<p style="font-size: 0.95rem; line-height: 1.6;">{cardCopy(game)}</p>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="panel animate-up">
			<div class="section-header">
				<div>
					<div class="kicker">Helpful answers</div>
					<h2>FAQs</h2>
				</div>
				<p>
					A quick guide for visitors who are new to tabletop RPGs or deciding what
					to try next.
				</p>
			</div>
			<div class="faq-grid">
				{faqs.map((faq) => (
					<details class="faq-item">
						<summary>{faq.question}</summary>
						<div class="faq-answer">
							<p>{faq.answer}</p>
						</div>
					</details>
				))}
			</div>
		</section>

		<section id="submit-your-game" class="panel submit-panel animate-up">
			<div class="section-header">
				<div>
					<div class="kicker">Share a recommendation</div>
					<h2>Submit Your Game</h2>
				</div>
				<p>
					Know a game that belongs in the directory? Send it our way so more
					players can discover it.
				</p>
			</div>
			<div class="submit-layout">
				<div class="prose" style="font-size: 1rem;">
					<p>
						The best submissions include the game title, official website, cover
						image, and a clear summary of what makes it worth exploring.
					</p>
					<p>
						If you’re suggesting a correction, include the item name and the detail
						that needs to be updated so it can be reviewed quickly.
					</p>
				</div>
				<div class="stack" style="gap: 12px;">
					<a href="/submit-game" class="button-link primary">
						Open the submission form
					</a>
					<a href="https://x.com/augustinbralley" class="button-link">
						Contact on X
					</a>
				</div>
			</div>
		</section>
	</div>

	<style>
		.hero-section {
			display: grid;
			grid-template-columns: 1.1fr 0.9fr;
			gap: 60px;
			align-items: center;
			padding: 150px 0 80px;
			min-height: 560px;
		}

		.hero-content h1 {
			font-size: clamp(2.8rem, 5.2vw, 4.8rem);
			line-height: 0.98;
			margin: 24px 0;
			letter-spacing: -0.025em;
			font-weight: 800;
		}

		.hero-content p {
			font-size: 1.25rem;
			color: var(--muted);
			max-width: 560px;
			line-height: 1.6;
		}

		.hero-stats {
			display: flex;
			gap: 32px;
			margin: 36px 0;
		}

		.stat-pill {
			display: flex;
			flex-direction: column;
			gap: 4px;
		}

		.stat-pill strong {
			font-size: 1.6rem;
			color: var(--text);
			font-weight: 800;
		}

		.stat-pill span {
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: var(--muted);
			font-weight: 700;
		}

		.gold-star {
			color: var(--gold-accent);
			font-size: 1.5rem;
		}

		.hero-actions {
			display: flex;
			gap: 18px;
			margin-top: 12px;
		}

		.hero-visual {
			perspective: 1200px;
			z-index: 10;
		}
		
		.hero-image-stack {
			position: relative !important;
			height: 480px !important;
			width: 100% !important;
			max-width: 440px !important;
			margin-left: auto;
			display: block !important;
		}

		.hero-image-card {
			position: absolute !important;
			top: 0 !important;
			left: 0 !important;
			width: 100% !important;
			height: 100% !important;
			border-radius: 32px;
			overflow: hidden;
			box-shadow: 0 12px 48px rgba(31, 26, 22, 0.15);
			border: 1px solid rgba(255, 255, 255, 0.1);
			transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
			background: var(--bg);
			display: block !important;
		}

		.hero-image-card img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		/* The Fan */
		.horror { transform: rotate(-10deg) translate(-20px, 10px) !important; z-index: 1 !important; }
		.space { transform: rotate(-4deg) translate(-10px, 5px) !important; z-index: 2 !important; }
		.cyberpunk { transform: rotate(4deg) translate(10px, -5px) !important; z-index: 3 !important; }
		.fantasy { transform: rotate(10deg) translate(20px, -10px) !important; z-index: 4 !important; }

		.hero-image-stack:hover .horror { transform: rotate(-18deg) translate(-80px, 40px) scale(1.05) !important; z-index: 10 !important; }
		.hero-image-stack:hover .space { transform: rotate(-8deg) translate(-40px, 20px) scale(1.05) !important; z-index: 11 !important; }
		.hero-image-stack:hover .cyberpunk { transform: rotate(8deg) translate(40px, -20px) scale(1.05) !important; z-index: 12 !important; }
		.hero-image-stack:hover .fantasy { transform: rotate(18deg) translate(80px, -40px) scale(1.05) !important; z-index: 13 !important; }

		.hero-image-stack:hover .hero-image-card {
			box-shadow: 0 40px 80px rgba(31, 26, 22, 0.3) !important;
		}

		@media (max-width: 960px) {
			.hero-section {
				grid-template-columns: 1fr;
				text-align: center;
				padding: 50px 0;
			}
			.hero-content p {
				margin-inline: auto;
			}
			.hero-stats, .hero-actions {
				justify-content: center;
			}
			.hero-visual {
				order: -1;
				max-width: 440px;
				margin: 0 auto;
			}
		}

		.game-card {
			position: relative;
			transition: all 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
		}

		.game-card:hover {
			transform: translateY(-10px) scale(1.025);
			box-shadow: 0 40px 80px rgba(31, 26, 22, 0.14);
		}

		.section-header h2 {
			position: relative;
			display: inline-block;
			margin-bottom: 24px;
		}

		.section-header h2::after {
			content: "";
			position: absolute;
			bottom: -12px;
			left: 0;
			width: 72px;
			height: 4px;
			background: var(--accent);
			border-radius: 2px;
		}

		.faq-item {
			background: var(--surface-glass);
			border: 1px solid var(--line);
			border-radius: 20px;
			padding: 4px;
			transition: all 0.25s ease;
		}

		.faq-item:hover {
			border-color: var(--line-strong);
			background: var(--surface);
		}

		.faq-item summary {
			padding: 18px 24px;
			font-weight: 700;
			cursor: pointer;
			list-style: none;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.faq-item summary::after {
			content: "→";
			color: var(--accent);
			transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
		}

		.faq-item[open] summary::after {
			transform: rotate(90deg);
		}

		.faq-answer {
			padding: 0 24px 24px;
			color: var(--muted);
			line-height: 1.7;
		}
	</style>
</Base>
