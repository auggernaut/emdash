---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	structuredData?: unknown[];
}

const { title, description, image, canonical, content, structuredData = [] } = Astro.props;

const logoSrc = "/_emdash/api/media/file/01KN700FE50XVF7AG34QJ4YMFM.webp";
const primaryLinks = [
	{ label: "Categories", url: "/categories" },
	{ label: "Submit", url: "/submit-game" },
	{ label: "Blog", url: "/blog" },
];

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: "website",
	title,
	description,
	canonical,
	image,
	content,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		{
			structuredData.map((item) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
			))
		}
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<nav class="nav-shell">
				<a href="/" class="brand">
					<img class="brand-logo" src={logoSrc} alt="TTRPG Games" />
					<span class="brand-copy">
						<strong>TTRPG Games Directory</strong>
						<small>Discover your next tabletop roleplay game.</small>
					</span>
				</a>
				<div class="nav-links">
					{primaryLinks.map((item) => (
						<a href={item.url} class="nav-link">
							{item.label}
						</a>
					))}
				</div>
				<div class="nav-search">
						<LiveSearch
							class="header-search-component"
							style="display:block;width:100%;max-width:none;inline-size:100%;"
							inputClass="header-search-input"
							resultsClass="header-search-results"
							placeholder="Search directory"
							collections={["games", "category_pages"]}
							searchPage="/search"
							routeMap={{ games: "/item/:path", category_pages: "/category/:path" }}
						/>
				</div>
			</nav>
		</header>

		<main class="page-shell">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-grid">
				<div class="footer-column">
					<strong>TTRPG Games Directory</strong>
					<p>
						A tabletop RPG guide for players who want clearer ways to compare
						games, narrow the field, and choose what to play next.
					</p>
				</div>
				<div class="footer-column">
					<strong>Explore</strong>
					<div class="footer-links">
						<a href="/">Home</a>
						<a href="/categories">Categories</a>
						<a href="/#top-rated-games">Top Rated Games</a>
						<a href="/#recently-added-games">Recently Added</a>
					</div>
				</div>
				<div class="footer-column">
					<strong>Contact</strong>
					<p>Have a game suggestion or correction to share?</p>
					<div class="footer-links">
						<a href="/submit-game">Submit your game</a>
						<a href="https://x.com/augustinbralley">Contact on X</a>
					</div>
				</div>
			</div>
			<div class="footer-policies">
				<a href="/terms-of-use">Terms of Use</a>
				<a href="/privacy-policy">Privacy Policy</a>
			</div>
			<div class="footer-meta">
				<span>© 2026 TTRPG Games Directory. All rights reserved.</span>
			</div>
		</footer>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f5efe7;
		--surface: rgba(255, 255, 255, 0.84);
		--surface-strong: #fffdf9;
		--line: rgba(120, 97, 74, 0.14);
		--line-strong: rgba(120, 97, 74, 0.24);
		--text: #1f1a16;
		--muted: #6b5f53;
		--accent: #b14e2c;
		--accent-strong: #7a331d;
		--accent-soft: rgba(240, 172, 138, 0.14);
		--pill: rgba(122, 51, 29, 0.05);
		--success: #2f6f4f;
		--shadow: 0 22px 44px rgba(31, 26, 22, 0.08);
		--shadow-soft: 0 12px 24px rgba(31, 26, 22, 0.045);
		--radius: 18px;
		font-family:
			"Spectral",
			"Iowan Old Style",
			"Palatino Linotype",
			"Book Antiqua",
			Palatino,
			serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background:
			radial-gradient(circle at top right, rgba(243, 215, 200, 0.18), transparent 24%),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.68), transparent 18%),
			linear-gradient(180deg, #fbf8f4 0%, var(--bg) 100%);
		color: var(--text);
	}

	body {
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.site-header,
	.page-shell,
	.site-footer {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
	}

	.site-header {
		padding: 18px 0 18px;
	}

	.nav-shell {
		position: relative;
		display: grid;
		grid-template-columns: auto auto minmax(0, 1fr);
		align-items: center;
		gap: 22px;
		padding: 16px 18px;
		border: 1px solid var(--line);
		border-radius: 22px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 252, 247, 0.88));
		box-shadow: 0 10px 26px rgba(31, 26, 22, 0.04);
		overflow: hidden;
	}

	.nav-shell::before {
		content: "";
		position: absolute;
		inset: 0 0 auto;
		height: 3px;
		background: linear-gradient(90deg, rgba(177, 78, 44, 0.75), rgba(177, 78, 44, 0.12));
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
	}

	.brand-logo {
		width: 144px;
		height: auto;
		flex: 0 0 auto;
		filter: drop-shadow(0 4px 10px rgba(31, 26, 22, 0.08));
	}

	.brand-copy {
		display: grid;
		gap: 3px;
		min-width: 0;
	}

	.brand-copy strong {
		font-size: 1.18rem;
		letter-spacing: 0.015em;
	}

	.brand-copy small {
		color: var(--muted);
		font-size: 0.92rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

		.nav-links {
			display: inline-flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 10px;
			justify-self: end;
		}

	.nav-link {
		position: relative;
		padding: 8px 2px;
		border-radius: 0;
		font-size: 0.97rem;
		color: var(--muted);
		transition: color 0.18s ease;
	}

	.nav-link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 2px;
		height: 1.5px;
		background: linear-gradient(90deg, var(--accent), transparent);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.18s ease;
	}

	.nav-link:hover {
		color: var(--text);
	}

	.nav-link:hover::after {
		transform: scaleX(1);
	}

		.nav-search {
			min-width: 0;
			width: 100%;
			display: block;
			justify-self: stretch;
		}

		.nav-search > .header-search-component,
		.nav-search emdash-live-search.header-search-component,
		.nav-search .header-search-component,
		.nav-search .header-search-component form,
		.nav-search .header-search-component .emd-search-form {
			width: 100% !important;
			max-width: none;
			min-width: 0;
			display: block !important;
			inline-size: 100%;
		}

		.nav-search .header-search-input,
		.nav-search .header-search-component input,
		.nav-search .header-search-component input[type="search"] {
			width: 100%;
			border: 1px solid var(--line);
			border-radius: 14px;
			padding: 12px 18px;
			background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(251, 246, 240, 0.92));
			box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
			appearance: none;
			font: inherit;
			font-size: 0.95rem;
			line-height: 1.2;
			color: var(--text);
		}

		.nav-search .header-search-input:focus,
		.nav-search .header-search-component input:focus,
		.nav-search .header-search-component input[type="search"]:focus {
			outline: none;
			border-color: var(--line-strong);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.82),
				0 0 0 4px rgba(177, 78, 44, 0.08);
		}

		.nav-search .header-search-input::placeholder,
		.nav-search .header-search-component input::placeholder,
		.nav-search .header-search-component input[type="search"]::placeholder {
			color: var(--muted);
			opacity: 1;
			font-size: 0.92rem;
		}

	.page-shell {
		padding-bottom: 56px;
	}

	.site-footer {
		display: grid;
		gap: 20px;
		padding: 8px 0 44px;
		color: var(--muted);
	}

	.site-footer p {
		margin: 6px 0 0;
		max-width: 40rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 20px;
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.66);
		box-shadow: var(--shadow-soft);
	}

	.footer-column {
		display: grid;
		gap: 10px;
		align-content: start;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.footer-links a {
		padding: 9px 12px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.62);
		border: 1px solid var(--line);
	}

	.footer-meta {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		font-size: 0.92rem;
	}

	.footer-policies {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		justify-content: center;
		font-size: 0.92rem;
	}

	.footer-policies a {
		color: var(--muted);
		text-decoration: underline;
		text-underline-offset: 0.16em;
	}

	.footer-policies a:hover {
		color: var(--text);
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 0 0 0 12px;
		border-radius: 0;
		background: none;
		border-left: 3px solid rgba(177, 78, 44, 0.75);
		color: var(--accent-strong);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.hero-card,
	.panel,
	.game-card,
	.category-card,
	.meta-card {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--surface);
		box-shadow: var(--shadow-soft);
	}

	.hero-card,
	.panel,
	.meta-card {
		padding: 24px;
	}

	.hero-card {
		position: relative;
		padding: 38px 40px;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 244, 0.8)),
			var(--surface);
	}

	.hero-card::before {
		content: "";
		position: absolute;
		inset: 0 0 auto;
		height: 4px;
		background: linear-gradient(90deg, var(--accent), rgba(177, 78, 44, 0.18) 55%, transparent);
	}

	.hero-card::after {
		content: "";
		position: absolute;
		top: -60px;
		right: -40px;
		width: 220px;
		height: 220px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(243, 215, 200, 0.24), transparent 70%);
		pointer-events: none;
	}

	.hero-card > p {
		max-width: 48rem;
		font-size: 1.06rem;
		line-height: 1.7;
	}

	.hero-card h1 {
		font-size: clamp(2.6rem, 4.8vw, 4.5rem);
		line-height: 0.95;
		letter-spacing: -0.03em;
		text-wrap: pretty;
	}

	.category-hero-card h1 {
		font-size: clamp(2.4rem, 4.2vw, 4.8rem);
		text-wrap: pretty;
	}

	.home-hero-card h1 {
		text-wrap: pretty;
	}

	.item-hero-layout h1 {
		max-width: 14ch;
	}

	.hero-card > :not(img) {
		position: relative;
		z-index: 1;
	}

	.section-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: end;
		gap: 14px;
		margin-bottom: 18px;
	}

	.section-header h1,
	.section-header h2 {
		margin: 0;
		font-size: clamp(1.8rem, 3vw, 2.7rem);
		line-height: 1;
	}

	.section-header p {
		margin: 0;
		max-width: 42rem;
		color: var(--muted);
	}

	.grid {
		display: grid;
		gap: 24px;
	}

	.section-actions {
		margin-top: 18px;
	}

	.grid.games {
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	}

	.grid.categories {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.game-card,
	.category-card {
		overflow: hidden;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.game-card a,
	.category-card a {
		display: block;
		height: 100%;
	}

		.game-card img {
			aspect-ratio: 16 / 10;
			object-fit: cover;
			background: linear-gradient(145deg, #e5d7bf, #f7efe3);
		}

	.game-card:hover,
	.category-card:hover,
	.meta-card:hover,
	.panel:hover {
		border-color: var(--line-strong);
		box-shadow: var(--shadow);
	}

	.game-card:hover,
	.category-card:hover {
		transform: translateY(-3px);
	}

		.game-hero {
			display: flex;
			align-items: flex-start;
			align-self: start;
			justify-self: end;
			width: 100%;
			max-width: 420px;
		}

		.game-hero img {
			display: block;
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
			border-radius: var(--radius);
			background: linear-gradient(145deg, #e5d7bf, #f7efe3);
		}

	.card-body {
		padding: 20px;
	}

	.kicker,
	.muted {
		color: var(--muted);
	}

	.kicker {
		font-size: 0.86rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 700;
	}

	.card-body h2,
	.card-body h3,
	.hero-card h1,
	.meta-card h2 {
		margin: 10px 0 10px;
	}

	.card-body p,
	.hero-card p,
	.meta-card p {
		margin: 0;
		color: var(--muted);
	}

	.related-item {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
		align-items: start;
		padding: 12px;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 253, 248, 0.72);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.related-item:hover {
		transform: translateY(-2px);
		border-color: var(--line-strong);
		box-shadow: 0 14px 30px rgba(48, 28, 14, 0.08);
	}

	.related-item img {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 14px;
		background: linear-gradient(145deg, #e5d7bf, #f7efe3);
	}

	.related-item-copy {
		min-width: 0;
	}

	.related-item-copy strong {
		display: block;
	}

	.related-item-copy p {
		margin: 0;
	}

	.related-item-copy :is(p, ul, ol) + :is(p, ul, ol) {
		margin-top: 0.55rem;
	}

		.meta-note {
			font-size: 0.95rem;
			line-height: 1.5;
		}

	.meta-note a {
		color: var(--accent-strong);
		text-decoration: underline;
		text-underline-offset: 0.16em;
	}

	.at-a-glance-panel {
		padding: 18px 20px;
		background: rgba(255, 250, 245, 0.84);
	}

	.at-a-glance-copy {
		margin-top: 10px;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text);
	}

	.at-a-glance-copy :is(p, ul, ol) {
		margin: 0;
	}

	.badges,
	.term-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.badge,
	.term {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 7px 10px;
		border-radius: 12px;
		background: var(--pill);
		font-size: 0.82rem;
		border: 1px solid rgba(120, 97, 74, 0.08);
	}

	.badge[data-tone="strong"] {
		background: var(--accent-soft);
		color: var(--accent-strong);
	}

	.badge[data-tone="success"] {
		background: rgba(47, 111, 79, 0.12);
		color: var(--success);
	}

	.button-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 16px;
		border-radius: 12px;
		border: 1px solid var(--line-strong);
		background: rgba(255, 255, 255, 0.86);
		font-weight: 600;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease,
			background-color 0.18s ease;
	}

	.button-link.primary {
		background: linear-gradient(145deg, var(--accent), var(--accent-strong));
		border-color: transparent;
		color: #fff9f2;
		box-shadow: 0 12px 24px rgba(177, 78, 44, 0.2);
	}

	.button-link:hover {
		transform: translateY(-1px);
		border-color: var(--line-strong);
		box-shadow: var(--shadow-soft);
	}

	.stack {
		display: grid;
		gap: 28px;
	}

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.breadcrumbs a {
		color: var(--muted);
	}

	.breadcrumbs a:hover {
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 0.16em;
	}

	.breadcrumb-separator {
		color: rgba(107, 95, 83, 0.65);
	}

		.detail-layout {
			display: grid;
			grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.7fr);
			gap: 24px;
		}

	.item-hero-layout {
		grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
		align-items: start;
	}

	.item-hero-layout > :first-child {
		align-self: start;
	}

	.prose {
		font-size: 1.02rem;
		line-height: 1.75;
	}

	.prose h2,
	.prose h3 {
		margin-top: 1.7em;
		margin-bottom: 0.5em;
		line-height: 1.2;
	}

	.prose p,
	.prose ul,
	.prose ol,
	.prose table {
		margin: 0 0 1.1em;
	}

	.prose table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.96rem;
	}

	.prose th,
	.prose td {
		padding: 12px;
		border: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
	}

	.prose ul,
	.prose ol {
		padding-left: 1.3rem;
	}

	.faq-grid {
		display: grid;
		gap: 14px;
	}

	.faq-item {
		padding: 0;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.72);
		overflow: hidden;
		transition:
			border-color 0.18s ease,
			box-shadow 0.18s ease,
			background-color 0.18s ease;
	}

	.faq-item summary {
		cursor: pointer;
		font-weight: 700;
		list-style: none;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 14px;
		padding: 18px 20px;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary::after {
		content: "+";
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 248, 241, 0.95);
		color: var(--accent-strong);
		font-size: 1.2rem;
