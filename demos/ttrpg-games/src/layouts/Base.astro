---
import { getMenu } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, description, image, canonical, content } = Astro.props;

const menu = await getMenu("primary");
const logoSrc = "/_emdash/api/media/file/01KN700FE50XVF7AG34QJ4YMFM.webp";

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: "website",
	title,
	description,
	canonical,
	image,
	content,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<nav class="nav-shell">
				<a href="/" class="brand">
					<img class="brand-logo" src={logoSrc} alt="TTRPG Games" />
					<span class="brand-copy">
						<strong>TTRPG Games</strong>
						<small>Discover tabletop RPGs by genre, style, and tone</small>
					</span>
				</a>
				<div class="nav-links">
					{
						menu?.items.map((item) => (
							<a href={item.url} target={item.target} class="nav-link">
								{item.label}
							</a>
						))
					}
				</div>
				<div class="nav-search">
						<LiveSearch
							class="header-search-component"
							style="display:block;width:100%;max-width:none;inline-size:100%;"
							inputClass="header-search-input"
							resultsClass="header-search-results"
							placeholder="Search directory"
							collections={["games", "category_pages"]}
							searchPage="/search"
							routeMap={{ games: "/item/:path", category_pages: "/category/:path" }}
						/>
				</div>
			</nav>
		</header>

		<main class="page-shell">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-grid">
				<div class="footer-column">
					<strong>TTRPG Games Directory</strong>
					<p>
						A discovery guide for tabletop RPG players who want faster ways to
						compare games by genre, mechanics, and tone.
					</p>
				</div>
				<div class="footer-column">
					<strong>Explore</strong>
					<div class="footer-links">
						<a href="/">Home</a>
						<a href="/categories">Categories</a>
						<a href="/#top-rated-games">Top Rated Games</a>
						<a href="/#recently-added-games">Recently Added</a>
					</div>
				</div>
				<div class="footer-column">
					<strong>Contact</strong>
					<p>Have a game suggestion or correction to share?</p>
					<div class="footer-links">
						<a href="/#submit-your-game">Submit your game</a>
						<a href="https://x.com/augustinbralley">Contact on X</a>
					</div>
				</div>
				<div class="footer-column">
					<strong>Legal</strong>
					<p>
						Game names, logos, cover art, and trademarks belong to their
						respective owners. This directory is for discovery and editorial use.
					</p>
				</div>
			</div>
			<div class="footer-meta">
				<span>© 2026 TTRPG Games Directory. All rights reserved.</span>
			</div>
		</footer>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f6f1ea;
		--surface: rgba(255, 255, 255, 0.82);
		--surface-strong: #fffdf9;
		--line: rgba(120, 97, 74, 0.16);
		--line-strong: rgba(120, 97, 74, 0.28);
		--text: #1f1a16;
		--muted: #6b5f53;
		--accent: #b14e2c;
		--accent-strong: #7a331d;
		--accent-soft: rgba(240, 172, 138, 0.18);
		--pill: rgba(122, 51, 29, 0.06);
		--success: #2f6f4f;
		--shadow: 0 18px 48px rgba(31, 26, 22, 0.07);
		--shadow-soft: 0 10px 28px rgba(31, 26, 22, 0.05);
		--radius: 20px;
		font-family:
			"Spectral",
			"Iowan Old Style",
			"Palatino Linotype",
			"Book Antiqua",
			Palatino,
			serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background:
			radial-gradient(circle at top right, rgba(243, 215, 200, 0.34), transparent 28%),
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.78), transparent 24%),
			linear-gradient(180deg, #fbf8f3 0%, var(--bg) 100%);
		color: var(--text);
	}

	body {
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.site-header,
	.page-shell,
	.site-footer {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
	}

	.site-header {
		padding: 24px 0 20px;
	}

		.nav-shell {
			display: grid;
			grid-template-columns: auto auto minmax(0, 1fr);
			align-items: center;
			gap: 18px;
			padding: 16px 18px;
			border: 1px solid var(--line);
			border-radius: 26px;
			background: rgba(255, 255, 255, 0.68);
			backdrop-filter: blur(12px);
			box-shadow: var(--shadow-soft);
		}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
	}

		.brand-logo {
			width: 150px;
			height: auto;
			flex: 0 0 auto;
		}

	.brand-copy {
		display: grid;
		gap: 3px;
		min-width: 0;
	}

	.brand-copy strong {
		font-size: 1.18rem;
		letter-spacing: 0.02em;
	}

	.brand-copy small {
		color: var(--muted);
		font-size: 0.95rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

		.nav-links {
			display: inline-flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 10px;
			justify-self: end;
		}

	.nav-link {
		padding: 10px 12px;
		border-radius: 12px;
		font-size: 0.96rem;
		color: var(--muted);
		transition:
			background-color 0.18s ease,
			color 0.18s ease;
	}

	.nav-link:hover {
		background: rgba(255, 255, 255, 0.72);
		color: var(--text);
	}

		.nav-search {
			min-width: 0;
			width: 100%;
			display: block;
			justify-self: stretch;
		}

		.nav-search > .header-search-component,
		.nav-search emdash-live-search.header-search-component,
		.nav-search .header-search-component,
		.nav-search .header-search-component form,
		.nav-search .header-search-component .emd-search-form {
			width: 100% !important;
			max-width: none;
			min-width: 0;
			display: block !important;
			inline-size: 100%;
		}

		.nav-search .header-search-input,
		.nav-search .header-search-component input,
		.nav-search .header-search-component input[type="search"] {
			width: 100%;
			border: 1px solid var(--line);
			border-radius: 14px;
			padding: 12px 18px;
			background: rgba(255, 255, 255, 0.9);
			box-shadow: none;
			appearance: none;
			font: inherit;
			font-size: 0.95rem;
			line-height: 1.2;
			color: var(--text);
		}

		.nav-search .header-search-input:focus,
		.nav-search .header-search-component input:focus,
		.nav-search .header-search-component input[type="search"]:focus {
			outline: none;
			border-color: var(--line-strong);
		}

		.nav-search .header-search-input::placeholder,
		.nav-search .header-search-component input::placeholder,
		.nav-search .header-search-component input[type="search"]::placeholder {
			color: var(--muted);
			opacity: 1;
			font-size: 0.92rem;
		}

	.page-shell {
		padding-bottom: 56px;
	}

	.site-footer {
		display: grid;
		gap: 20px;
		padding: 8px 0 44px;
		color: var(--muted);
	}

	.site-footer p {
		margin: 6px 0 0;
		max-width: 40rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 20px;
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.66);
		box-shadow: var(--shadow-soft);
	}

	.footer-column {
		display: grid;
		gap: 10px;
		align-content: start;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.footer-links a {
		padding: 9px 12px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.62);
		border: 1px solid var(--line);
	}

	.footer-meta {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		font-size: 0.92rem;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 7px 12px;
		border-radius: 999px;
		background: var(--accent-soft);
		color: var(--accent-strong);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-card,
	.panel,
	.game-card,
	.category-card,
	.meta-card {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--surface);
		box-shadow: var(--shadow-soft);
	}

	.hero-card,
	.panel,
	.meta-card {
		padding: 24px;
	}

	.hero-card {
		padding: 40px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 249, 243, 0.76)),
			var(--surface);
	}

	.hero-card > p {
		max-width: 48rem;
		font-size: 1.06rem;
		line-height: 1.7;
	}

	.section-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: end;
		gap: 14px;
		margin-bottom: 18px;
	}

	.section-header h1,
	.section-header h2 {
		margin: 0;
		font-size: clamp(1.8rem, 3vw, 2.7rem);
		line-height: 1;
	}

	.section-header p {
		margin: 0;
		max-width: 42rem;
		color: var(--muted);
	}

	.grid {
		display: grid;
		gap: 24px;
	}

	.section-actions {
		margin-top: 18px;
	}

	.grid.games {
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	}

	.grid.categories {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.game-card,
	.category-card {
		overflow: hidden;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.game-card a,
	.category-card a {
		display: block;
		height: 100%;
	}

		.game-card img {
			aspect-ratio: 16 / 10;
			object-fit: cover;
			background: linear-gradient(145deg, #e5d7bf, #f7efe3);
		}

	.game-card:hover,
	.category-card:hover,
	.meta-card:hover,
	.panel:hover {
		border-color: var(--line-strong);
		box-shadow: var(--shadow);
	}

	.game-card:hover,
	.category-card:hover {
		transform: translateY(-3px);
	}

		.game-hero {
			display: flex;
			align-items: flex-start;
		}

		.game-hero img {
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
			border-radius: var(--radius);
			background: linear-gradient(145deg, #e5d7bf, #f7efe3);
		}

	.card-body {
		padding: 20px;
	}

	.kicker,
	.muted {
		color: var(--muted);
	}

	.kicker {
		font-size: 0.86rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 700;
	}

	.card-body h2,
	.card-body h3,
	.hero-card h1,
	.meta-card h2 {
		margin: 10px 0 10px;
	}

	.card-body p,
	.hero-card p,
	.meta-card p {
		margin: 0;
		color: var(--muted);
	}

	.related-item {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
		align-items: start;
		padding: 12px;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 253, 248, 0.72);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.related-item:hover {
		transform: translateY(-2px);
		border-color: var(--line-strong);
		box-shadow: 0 14px 30px rgba(48, 28, 14, 0.08);
	}

	.related-item img {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 14px;
		background: linear-gradient(145deg, #e5d7bf, #f7efe3);
	}

	.related-item-copy {
		min-width: 0;
	}

	.related-item-copy strong {
		display: block;
	}

	.related-item-copy p {
		margin: 0;
	}

	.related-item-copy :is(p, ul, ol) + :is(p, ul, ol) {
		margin-top: 0.55rem;
	}

		.meta-note {
			font-size: 0.95rem;
			line-height: 1.5;
		}

		.meta-note a {
			color: var(--accent-strong);
			text-decoration: underline;
			text-underline-offset: 0.16em;
		}

	.badges,
	.term-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.badge,
	.term {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 7px 10px;
		border-radius: 12px;
		background: var(--pill);
		font-size: 0.82rem;
		border: 1px solid rgba(120, 97, 74, 0.08);
	}

	.badge[data-tone="strong"] {
		background: var(--accent-soft);
		color: var(--accent-strong);
	}

	.badge[data-tone="success"] {
		background: rgba(47, 111, 79, 0.12);
		color: var(--success);
	}

	.button-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 16px;
		border-radius: 14px;
		border: 1px solid var(--line-strong);
		background: rgba(255, 255, 255, 0.86);
		font-weight: 600;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease,
			background-color 0.18s ease;
	}

	.button-link.primary {
		background: linear-gradient(145deg, var(--accent), var(--accent-strong));
		border-color: transparent;
		color: #fff9f2;
		box-shadow: 0 12px 24px rgba(177, 78, 44, 0.2);
	}

	.button-link:hover {
		transform: translateY(-1px);
		border-color: var(--line-strong);
		box-shadow: var(--shadow-soft);
	}

	.stack {
		display: grid;
		gap: 28px;
	}

	.detail-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.7fr);
		gap: 24px;
	}

	.prose {
		font-size: 1.02rem;
		line-height: 1.75;
	}

	.prose h2,
	.prose h3 {
		margin-top: 1.7em;
		margin-bottom: 0.5em;
		line-height: 1.2;
	}

	.prose p,
	.prose ul,
	.prose ol,
	.prose table {
		margin: 0 0 1.1em;
	}

	.prose table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.96rem;
	}

	.prose th,
	.prose td {
		padding: 12px;
		border: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
	}

	.prose ul,
	.prose ol {
		padding-left: 1.3rem;
	}

	.faq-grid {
		display: grid;
		gap: 14px;
	}

	.faq-item {
		padding: 16px 18px;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.66);
	}

	.faq-item summary {
		cursor: pointer;
		font-weight: 700;
		list-style: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item p {
		margin: 12px 0 0;
		color: var(--muted);
		line-height: 1.65;
	}

	.submit-panel {
		background:
			radial-gradient(circle at top right, rgba(243, 215, 200, 0.55), transparent 35%),
			var(--surface);
	}

	.submit-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.8fr);
		gap: 20px;
		align-items: start;
	}

		.empty-state {
			padding: 28px;
			border: 1px dashed var(--line-strong);
			border-radius: var(--radius);
			background: rgba(255, 253, 248, 0.75);
			color: var(--muted);
		}

		.search-results {
			display: grid;
			gap: 16px;
		}

		.search-result {
			display: grid;
			gap: 10px;
			padding: 20px;
			border: 1px solid var(--line);
			border-radius: 18px;
			background: rgba(255, 253, 248, 0.7);
			transition:
				transform 0.18s ease,
				border-color 0.18s ease,
				box-shadow 0.18s ease;
		}

		.search-result:hover {
			transform: translateY(-2px);
			border-color: var(--line-strong);
			box-shadow: 0 14px 30px rgba(48, 28, 14, 0.08);
		}

		.search-result-head {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 12px;
		}

		.search-result h2 {
			margin: 0;
			font-size: 1.2rem;
		}

		.search-result p {
			margin: 0;
			color: var(--muted);
			line-height: 1.6;
		}

		.search-result mark {
			background: var(--accent-soft);
			color: var(--accent-strong);
			padding: 0 0.15em;
			border-radius: 0.2em;
		}

		@media (max-width: 960px) {
			.nav-shell,
			.detail-layout,
			.submit-layout {
				grid-template-columns: 1fr;
		}

		.nav-links {
			justify-content: flex-start;
		}

		.hero-card {
			padding: 28px;
		}

		.footer-meta {
			justify-content: flex-start;
		}
	}
</style>
